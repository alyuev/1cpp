Перем Журнал;

Перем Параметры;

//Функция Конт(Конт) Возврат Конт; КонецФункции

Процедура ПриОткрытии()

	Журнал = СоздатьОбъект("ЖурналВызоваМетодов");
	Журнал.ДобавитьЗапись("Форма::ПриОткрытии");

	Параметры = Форма.Параметр;

	Если Параметры = "ВызватьСобытие" Тогда
		
		ОбъектФорма = СоздатьОбъект("Форма");
		ОбъектФорма.УстановитьФорму(Форма);
		
		Журнал.ДобавитьЗапись("КлассФорма::УстановитьФорму");
		
	//ИначеЕсли Параметры = "КОПВызватьСобытие" Тогда
	//	
	//	ОбъектФорма = СоздатьОбъект("КлассЭлементУправления");
	//	ОбъектФорма.УстановитьФорму(Форма);
	//	
	//	Журнал.ДобавитьЗапись("КлассФорма::УстановитьФорму");
	
	ИначеЕсли Параметры = "СоздатьЭлементУправленияПриОткрытии" Тогда
		ОбъектФорма = СоздатьОбъект("Форма");
		ОбъектФорма.УстановитьФорму(Форма);
		ОбъектФорма.СоздатьЭлементУправления("КлассЭлементУправления", "ИДОбъектаАктивИкс");

		Журнал.ДобавитьЗапись("Форма::ОбъектАктивИкс::УстановитьАтрибут");
		
	Иначе
	КонецЕсли;

	Форма.Параметр = Журнал;
	
КонецПроцедуры
        
// событие любого объекта "Форма"
Процедура ФормаПриСоздании(ФормаИсточник) Экспорт
	Журнал.ДобавитьЗапись("Форма::ФормаПриСоздании");
	Журнал.ДобавитьЗапись("Источник="+ТипЗначенияСтр(ФормаИсточник));
КонецПроцедуры

//Процедура ПриСоздании(ФормаИсточник) Экспорт
