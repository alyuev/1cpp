Перем гТабличноеПоле;
Перем гТекСтрокаТипСобытия;
Перем гМаксТипСобытия1С;
Перем гКартинкаРежимов;
Перем гКартинкаКатегорий;
Перем бПериодУстановлен;
Перем бЕстьИмяФайла;
Перем гПривязка;

// ----------------------------------------------------------------------------------------------------
Процедура ПриИзмененииРазмераОкна(ТипСобытия, Ширина, Высота)
	гПривязка.ПриИзмененииРазмераОкна(ТипСобытия, Ширина, Высота);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ПриДвиженииМыши(Сост, Лево, Верх)
	гПривязка.ПриДвиженииМыши(Сост, Лево, Верх);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ПриНажатииЛевойКнопки(Сост, Лево, Верх, ФСО)
	//гПривязка.ПриНажатииЛевойКнопки(Сост, Лево, Верх, ФСО);
	гПривязка.ПриНажатииЛевойКнопки(Сост, Лево, Верх);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ПриОтжатииЛевойКнопки(Сост, Лево, Верх)
	гПривязка.ПриОтжатииЛевойКнопки(Сост, Лево, Верх);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ЗаполнитьТипыСобытий()
	Перем ТипыСобытий, События, сзСоб;
	сзТипыСобытий.УдалитьВсе();
	гМаксТипСобытия1С = 0;

	ТипыСобытий = гТабличноеПоле.ПоставщикДанных.ТипыСобытий;

	Для А = 0 По ТипыСобытий.Количество() - 1 Цикл
		Если ТипыСобытий.Получить(А).Системный = 1 Тогда
			гМаксТипСобытия1С = гМаксТипСобытия1С + 1;
		КонецЕсли;
		сзТипыСобытий.ДобавитьЗначение(СоздатьОбъект("СписокЗначений"), ТипыСобытий.Получить(А).Описание);

		сзСоб = сзТипыСобытий.ПолучитьЗначение(сзТипыСобытий.РазмерСписка());
		сзСоб.Установить("Тип", ТипыСобытий.Получить(А).Индекс);
		сзСоб.Установить("События", СоздатьОбъект("СписокЗначений"));
		сзСоб = сзСоб.Получить("События");

		События = ТипыСобытий.Получить(А).События;
		Для Б = 0 По События.Количество() - 1 Цикл
			сзСоб.ДобавитьЗначение(События.Получить(Б).Индекс, События.Получить(Б).Описание);
		КонецЦикла;
	КонецЦикла;

	сзТипыСобытий.ТекущаяСтрока(1);

	гТекСтрокаТипСобытия = 0;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Функция ПоказатьСобытия(бНадо = 0)
	Перем сзСоб;
	чФлаг = ?(сзТипыСобытий.ТекущаяСтрока() >= гМаксТипСобытия1С, ?(Форма.Закладки.ТекущаяСтрока() = 3, 1, 0), 0);
	Форма.кнДобавитьСобытие.Видимость(чФлаг);
	Форма.кнУдалитьСобытие.Видимость(чФлаг);
	Форма.кнОчиститьСобытия.Видимость(чФлаг);
	Если (бНадо = 0) И (гТекСтрокаТипСобытия = сзТипыСобытий.ТекущаяСтрока()) Тогда
		Возврат "" ;
	КонецЕсли;
	Если гТекСтрокаТипСобытия > 0 Тогда
		Если сзТипыСобытий.РазмерСписка() >= гТекСтрокаТипСобытия Тогда
			сзСоб = сзТипыСобытий.ПолучитьЗначение(гТекСтрокаТипСобытия);
			Если Врег(ТипЗначенияСтр(сзСоб)) = "СПИСОКЗНАЧЕНИЙ" Тогда
				сзСобытия.Выгрузить(сзСоб.Получить("События"));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	гТекСтрокаТипСобытия = сзТипыСобытий.ТекущаяСтрока();
	сзТипыСобытий.ПолучитьЗначение(гТекСтрокаТипСобытия).Получить("События").Выгрузить(сзСобытия);
	Возврат "" ;
КонецФункции

// ----------------------------------------------------------------------------------------------------
Процедура ВремяНачКонПриИзменении()
	Форма.ВремяНач.Доступность(ФлажокВремяНач);
	Форма.ВремяКон.Доступность(ФлажокВремяКон);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ИмяФайлаВидимость(чНомер)
	Перем бФлаг;
	бФлаг = ?(чНомер = 1, бЕстьИмяФайла, 0);
	Форма.ИмяФайла.Видимость(бФлаг);
	Форма.тФайл.Видимость(бФлаг);
	Форма.кнИмяФайла.Видимость(бФлаг);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ПриВыбореЗакладки(чНомер, хзЗначение)
	Форма.ИспользоватьСлой("Основной," + Форма.Закладки.ПолучитьЗначение(чНомер), 2);
	Форма.кнИзменить.Видимость(?(чНомер = 1, 0, 1));
	ВремяНачКонПриИзменении();
	ИмяФайлаВидимость(чНомер);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ПриНачалеВыбораЗначения(ЭлементФормы, бФСО)
	Перем стрЭлементФормы, стрФайл, стрКаталог;
	стрЭлементФормы = Врег(ЭлементФормы);
	Если стрЭлементФормы = "ХЗОБЪЕКТ" Тогда
		бФСО = 0;
		чТипОбъекта = ТипЗначения(хзОбъект);
		Если (чТипОбъекта = 11) ИЛИ (чТипОбъекта = 12) ИЛИ (чТипОбъекта = 15) Тогда
			ОткрытьФорму(хзОбъект,, 1);
		КонецЕсли;
	ИначеЕсли стрЭлементФормы = "ИМЯФАЙЛА" Тогда
		бФСО = 0;
		стрКаталог = "";
		стрФайл = гТабличноеПоле.ПоставщикДанных.ИмяФайла;
		Если ФС.ВыбратьФайл(0, стрФайл, стрКаталог, "Выберите файл ЖР", "Файлы журнала регистрации (*.mlg)|*.mlg", "mlg", 0) = 1 Тогда
			гТабличноеПоле.ПоставщикДанных.ИмяФайла = стрКаталог + стрФайл;
			ИмяФайла = гТабличноеПоле.ПоставщикДанных.ИмяФайла;
			ЗаполнитьТипыСобытий();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ПриОткрытии(бФЧН)
	Перем сзСоб;

	Состояние("Инициализация...");

	Форма.ИспользоватьЗакладки(1);
	Форма.Закладки.ДобавитьЗначение("Журнал", "Журнал регистрации");
	Форма.Закладки.ДобавитьЗначение("Общие", "Общие параметры");
	Форма.Закладки.ДобавитьЗначение("События");
	Форма.Закладки.ДобавитьЗначение("Объекты");
	ПриВыбореЗакладки(1, );

	гПривязка = СоздатьОбъект("Общие.Форма.Привязка");
	гПривязка.УстановитьФорму(Форма);
	гПривязка.Привязка("кнИзменить,кнСбросить,кнОтбор,кнЗакрыть,кнТекСтрока,кнУстСтроку,кнВыборкаСтрок,ИспользоватьБуфер,кнИмяФайла", "T", "Форма", "L", "Форма");
	гПривязка.Привязка("Комментарий", "H", "Форма", "LW", "Форма");
	гПривязка.Привязка("ТабличноеПоле", "H", "Форма", "W", "Комментарий");
	гПривязка.Привязка("тОбъект,тФайл,тКомментарий,тОбработкаТиповСобытий,тПредставление", "T", "Форма");
	гПривязка.Привязка("хзОбъект,ИмяФайла,ФильтрКомментарий,ФильтрПредставление", "T", "Форма", "W", "Форма");
	гПривязка.Привязка("рТипыСобытий,рПользователи,сзПользователи,рОбъекты,сзОбъекты", "H", "Форма", "W", "Форма");
	гПривязка.Привязка("сзСобытия", "H", "Форма", "LW", "Форма");
	гПривязка.Привязка("сзТипыСобытий", "H", "Форма", "W", "сзСобытия");
	гПривязка.Привязка("кнДобавитьТипСобытия,кнУдалитьТипСобытия,кнОчиститьТипыСобытий,кнВсеТипыСобытий,кнУбратьТипыСобытий,кнИнвТипыСобытий", "T", "Форма", "L", "сзСобытия");
	гПривязка.Привязка("кнДобавитьСобытие,кнУдалитьСобытие,кнОчиститьСобытия,кнВсеСобытия,кнУбратьСобытия,кнИнвСобытия", "T", "Форма", "L", "Форма");

	Если бФЧН = 0 Тогда
		Предприятие = 1;
		Конфигуратор = 1;
		Монитор = 1;
		Отладчик = 1;

		Сеанс = 1;
		Административное = 1;
		ИзменениеДанных = 1;
		Информация = 1;
		Варнинг = 1;
		Ошибка = 1;

		ДатаНач = НачМесяца(РабочаяДата());
		ДатаКон = КонМесяца(РабочаяДата());

		ФлажокВремяНач = 0;
		ФлажокВремяКон = 0;

		ВремяНач = "00:00:00";
		ВремяКон = "23:59:59";
	КонецЕсли;

	ТД = СоздатьОбъект("Таблица");
	ТД.ИсходнаяТаблица("Ресурсы");
	ТД.ВывестиСекцию("Режимы");
	ТД.ВывестиСекцию("Категории");
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ТабличноеПолеПриАктивизацииСтроки(ТПоле)
	Перем лОбъект;

	Комментарий = Лев(ТПоле.ТекущиеДанные.Комментарий, 100);
	Форма.Обновить();

	лОбъект = ТПоле.ТекущиеДанные.Объект;
	чТипОбъекта = ТипЗначения(лОбъект);

	Если чТипОбъекта = 10 Тогда
		Форма.хзОбъект.НазначитьТип("Перечисление." + лОбъект.Вид());
	ИначеЕсли чТипОбъекта = 11 Тогда
		Форма.хзОбъект.НазначитьТип("Справочник." + лОбъект.Вид());
	ИначеЕсли чТипОбъекта = 12 Тогда
		Форма.хзОбъект.НазначитьТип("Документ." + лОбъект.Вид());
	ИначеЕсли чТипОбъекта = 13 Тогда
		Форма.хзОбъект.НазначитьТип("Календарь");
	ИначеЕсли чТипОбъекта = 14 Тогда
		Форма.хзОбъект.НазначитьТип("ВидРасчета");
	ИначеЕсли чТипОбъекта = 15 Тогда
		Форма.хзОбъект.НазначитьТип("Счет." + лОбъект.Вид());
	ИначеЕсли чТипОбъекта = 16 Тогда
		Форма.хзОбъект.НазначитьТип("ВидСубконто");
	ИначеЕсли чТипОбъекта = 17 Тогда
		Форма.хзОбъект.НазначитьТип("ПланСчетов");
	Иначе
		хзОбъект = ПолучитьПустоеЗначение();
		чТипОбъекта = 0;
	КонецЕсли;
	Форма.хзОбъект.НеИзменятьВид(1);

	Если чТипОбъекта > 0 Тогда
		хзОбъект = лОбъект;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ТабличноеПолеПриВыводеСтроки(ТПоле, ОформлениеСтроки, ДанныеСтроки)
	Перем стрДанные, стрГраница;
	чИндекс = Найти("ECDM", Врег(ДанныеСтроки.Режим));
	Если чИндекс > 0 Тогда
		Яч = ОформлениеСтроки.Ячейки.Режим;
		Яч.ОтображатьКартинку = 1;
		Яч.ИндексКартинки = чИндекс - 1;
	КонецЕсли;
	чИндекс = Найти("012345", ДанныеСтроки.Категория);
	Если чИндекс > 0 Тогда
		Яч = ОформлениеСтроки.Ячейки.Категория;
		Яч.ОтображатьКартинку = 1;
		Яч.ИндексКартинки = чИндекс - 1;
	КонецЕсли;
	Если бПериодУстановлен = 1 Тогда
		бОшибкаПорядка = 0;
		стрДанные = Формат(ДанныеСтроки.Дата, "DГГГГММДД") + ";" + ДанныеСтроки.Время;
		Если гТабличноеПоле.ПоставщикДанных.НачалоПериода <> Дата(0) Тогда
			стрГраница = Формат(гТабличноеПоле.ПоставщикДанных.НачалоПериода, "DГГГГММДД") + ";" + гТабличноеПоле.ПоставщикДанных.ВремяНачалаПериода;
			бОшибкаПорядка = ?(стрГраница > стрДанные, 1, бОшибкаПорядка);
		КонецЕсли;
		Если гТабличноеПоле.ПоставщикДанных.КонецПериода <> Дата(0) Тогда
			стрГраница = Формат(гТабличноеПоле.ПоставщикДанных.КонецПериода, "DГГГГММДД") + ";" + гТабличноеПоле.ПоставщикДанных.ВремяОкончанияПериода;
			бОшибкаПорядка = ?(стрГраница < стрДанные, 1, бОшибкаПорядка);
		КонецЕсли;
		Если бОшибкаПорядка = 1 Тогда
			ОформлениеСтроки.ЦветФона = 15790320;//240*256*256+240*256+240;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура УстановитьИнфоОПериоде()
	Перем дтНач, дтКон;
	дтНач = гТабличноеПоле.ПоставщикДанных.НачалоПериода;
	дтНач = ?(дтНач = Дата(0), "Начало журнала", Формат(дтНач, "DДДММГГГГ") + " " + гТабличноеПоле.ПоставщикДанных.ВремяНачалаПериода);
	дтКон = гТабличноеПоле.ПоставщикДанных.КонецПериода;
	дтКон = ?(дтКон = Дата(0), "Конец журнала", Формат(дтКон, "DДДММГГГГ") + " " + гТабличноеПоле.ПоставщикДанных.ВремяОкончанияПериода);
	Форма.тТекущийПериод.Заголовок(дтНач + РазделительСтрок + дтКон);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ПослеОткрытия()
	Перем А;

	гПривязка.ПослеОткрытия();

	Источник = СоздатьОбъект("LogProvider");

	Попытка // 1C++ ниже 2.5
		ТабличноеПоле = гПривязка.ПолучитьАтрибут("ТабличноеПоле").СоздатьЭлементУправления("ТабличноеПоле");
	Исключение // 1C++ 2.5
	    лФорма=СоздатьОбъект("Форма");
	    лФорма.УстановитьФорму(Форма);
	    ТабличноеПоле = лФорма.СоздатьЭлементУправления("ТабличноеПоле","ТабличноеПоле");
	КонецПопытки;
	
	ТабличноеПоле.СтильЗаголовков = 1;

	Колонки = ТабличноеПоле.Колонки;

	сзКолонки = СоздатьОбъект("СписокЗначений");
	сзКолонки.ДобавитьЗначение(19, "Режим");
	сзКолонки.ДобавитьЗначение(19, "Категория");
	Если Источник.ТестоваяСборка = 1 Тогда
		сзКолонки.ДобавитьЗначение(8, "Позиция");
		сзКолонки.Пометка(сзКолонки.РазмерСписка(), 1);
	КонецЕсли;
	сзКолонки.ДобавитьЗначение( 8, "Дата");
	сзКолонки.ДобавитьЗначение( 8, "Время");
	сзКолонки.ДобавитьЗначение(10, "User");
	сзКолонки.ДобавитьЗначение(10, "ТипСобытия");
	сзКолонки.ДобавитьЗначение(15, "Событие");
	сзКолонки.ДобавитьЗначение(15, "Комментарий");
	//сзКолонки.ДобавитьЗначение(10, "Объект");
	сзКолонки.ДобавитьЗначение(15, "ПредставлениеОбъекта");

	Для А = 1 По сзКолонки.РазмерСписка() Цикл
		стрДанные = "";
		чШирина = сзКолонки.ПолучитьЗначение(А, стрДанные);

		Колонка = Колонки.Добавить(стрДанные);
		Колонка.Данные = стрДанные;
		Колонка.Ширина = чШирина;
		Если А < 3 Тогда
			Колонка.Заголовок = Лев(стрДанные, 1);
			Колонка.ИзменениеРазмера = 0;
			Если А = 1 Тогда
				Колонка.УстановитьКартинкиСтрок(гКартинкаРежимов, 16);
			Иначе
				Колонка.УстановитьКартинкиСтрок(гКартинкаКатегорий, 16);
			КонецЕсли;
		Иначе
			Колонка.Заголовок = стрДанные;
		КонецЕсли;
		Если сзКолонки.Пометка(А) = 1 Тогда
			Колонка.ГоризонтальноеВыравнивание = 2;
		КонецЕсли;
	КонецЦикла;

	ТабличноеПоле.ПоставщикДанных = Источник;

	гТабличноеПоле = ТабличноеПоле;

	Попытка
		А = Источник.ИмяФайла;
		бЕстьИмяФайла = 1;
		ИмяФайла = А;
	Исключение
		бЕстьИмяФайла = 0;
	КонецПопытки;

	ЗаполнитьТипыСобытий();

	ИмяФайлаВидимость(1);

	УстановитьИнфоОПериоде();
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура УстановитьПериод()
	Перем дтНач, дтКон;
	дтНач = ?(ПустоеЗначение(ДатаНач) = 1, Дата(0), ДатаНач);
	дтКон = ?(ПустоеЗначение(ДатаКон) = 1, Дата(0), ДатаКон);
	Если (ФлажокВремяНач = 0) И (ФлажокВремяКон = 0) Тогда
		Если гТабличноеПоле.ПоставщикДанных.УстановитьПериод(дтНач, дтКон) = 1 Тогда
			УстановитьИнфоОПериоде();
			бПериодУстановлен = 1;
		КонецЕсли;
	Иначе
		Если гТабличноеПоле.ПоставщикДанных.УстановитьПериодРасш(дтНач, ?(ФлажокВремяНач = 1, ВремяНач, ""), дтКон, ?(ФлажокВремяКон = 1, ВремяКон, "")) = 1 Тогда
			УстановитьИнфоОПериоде();
			бПериодУстановлен = 1;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура СброситьПериод()
	Если гТабличноеПоле.ПоставщикДанных.УстановитьПериод() = 1 Тогда
		УстановитьИнфоОПериоде();
		бПериодУстановлен = 0;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура Режимы(чФлаг)
	Предприятие = ?(чФлаг = 2, ?(Предприятие = 1, 0, 1), чФлаг);
	Конфигуратор = ?(чФлаг = 2, ?(Конфигуратор = 1, 0, 1), чФлаг);
	Монитор = ?(чФлаг = 2, ?(Монитор = 1, 0, 1), чФлаг);
	Отладчик = ?(чФлаг = 2, ?(Отладчик = 1, 0, 1), чФлаг);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура Категории(чФлаг)
	Сеанс = ?(чФлаг = 2, ?(Сеанс = 1, 0, 1), чФлаг);
	Административное = ?(чФлаг = 2, ?(Административное = 1, 0, 1), чФлаг);
	ИзменениеДанных = ?(чФлаг = 2, ?(ИзменениеДанных = 1, 0, 1), чФлаг);
	Информация = ?(чФлаг = 2, ?(Информация = 1, 0, 1), чФлаг);
	Варнинг = ?(чФлаг = 2, ?(Варнинг = 1, 0, 1), чФлаг);
	Ошибка = ?(чФлаг = 2, ?(Ошибка = 1, 0, 1), чФлаг);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура УстановкаПометокВСписке(Список, Галка)
	Перем лВрем, лЗнач;
	Для А = 1 По Список.РазмерСписка() Цикл
		чФлаг = Список.Пометка(А);
		Список.Пометка(А, ?(Галка = 0, 0, ?(Галка = 1, 1, ?(чФлаг = 0, 1, 0))));
	КонецЦикла;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ТипыСобытий(чФлаг)
	УстановкаПометокВСписке(сзТипыСобытий, чФлаг);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура События(чФлаг)
	УстановкаПометокВСписке(сзСобытия, чФлаг);
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура Пользователи(чФлаг)
	Если чФлаг = 1 Тогда
		стрЮзер = "";
		Если ВвестиСтроку(стрЮзер, "Кто", 100, 0, 0) = 1 Тогда
			сзПользователи.ДобавитьЗначение(СокрЛП(стрЮзер));
		КонецЕсли;
	ИначеЕсли чФлаг = 2 Тогда
		чНомСтр = сзПользователи.ТекущаяСтрока();
		Если чНомСтр > 0 Тогда
			сзПользователи.УдалитьЗначение(чНомСтр, 1);
			Если сзПользователи.РазмерСписка() > 0 Тогда
				сзПользователи.ТекущаяСтрока(Мин(сзПользователи.РазмерСписка(), чНомСтр));
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли чФлаг = 3 Тогда
		сзПользователи.УдалитьВсе();
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ТипыСобытийСобытияЮзера(чФлаг, бТипСобытия)
	сзПриемник = ?(бТипСобытия = 1, сзТипыСобытий, сзСобытия);
	чМакс = ?(бТипСобытия = 1, гМаксТипСобытия1С, 1);
	Если чФлаг = 1 Тогда
		стрТипСоб = "";
		Если ВвестиСтроку(стрТипСоб, ?(бТипСобытия = 1, "Тип события", "Событие"), 100, 0, 0) = 1 Тогда
			стрТипСоб = Нрег(СокрЛП(стрТипСоб));
			Если сзПриемник.НайтиЗначение(стрТипСоб) = 0 Тогда
				Если бТипСобытия = 1 Тогда
					сзПриемник.ДобавитьЗначение(СоздатьОбъект("СписокЗначений"), стрТипСоб);
					сзСоб = сзПриемник.ПолучитьЗначение(сзПриемник.РазмерСписка());
					сзСоб.Установить("Тип", 138);
					сзСоб.Установить("События", СоздатьОбъект("СписокЗначений"));
				Иначе
					сзПриемник.ДобавитьЗначение(137, стрТипСоб);
				КонецЕсли;
				сзПриемник.Пометка(сзПриемник.РазмерСписка(), 1);
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли чФлаг = 2 Тогда
		чНомСтр = сзПриемник.ТекущаяСтрока();
		Если чНомСтр > чМакс Тогда
			сзПриемник.УдалитьЗначение(чНомСтр, 1);
			Если сзПриемник.РазмерСписка() > 0 Тогда
				гТекСтрокаТипСобытия = - 1;
				сзПриемник.ТекущаяСтрока(Мин(сзПриемник.РазмерСписка(), чНомСтр));
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли чФлаг = 3 Тогда
		Если сзПриемник.РазмерСписка() > чМакс Тогда
			сзПриемник.УдалитьЗначение(чМакс + 1, сзПриемник.РазмерСписка() - чМакс);
			Если сзПриемник.РазмерСписка() > 0 Тогда
				сзПриемник.ТекущаяСтрока(сзПриемник.РазмерСписка());
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура СписокМетаданных(стрТипМетаданных, сзРезультат, бЕстьПометки, бСамВид)
	Если бСамВид = 1 Тогда
		сзРезультат.ДобавитьЗначение(стрТипМетаданных, "<<" + Врег(стрТипМетаданных) + ">>");
	КонецЕсли;
	чКолво = Число(Шаблон("[Метаданные." + стрТипМетаданных + "()]"));
	Для А = 1 По чКолво Цикл
		стрВид = СокрЛП(Шаблон("[Метаданные." + стрТипМетаданных + "(" + А + ").Идентификатор]"));
		сзРезультат.ДобавитьЗначение(стрТипМетаданных + "." + стрВид);//, стрВид);
		Если бЕстьПометки = 1 Тогда
			сзРезультат.Пометка(А, 0);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ВидыОбъекты(чФлаг)
	Перем хзКонт;

	Если чФлаг <> 2 Тогда
		сзВыбор = СоздатьОбъект("СписокЗначений");
		сзВыбор.ДобавитьЗначение("Вид объекта");
		сзВыбор.ДобавитьЗначение("Объект");
		чВыбор = 0;
		Если сзВыбор.ВыбратьЗначение(,, чВыбор, 0, 1) = 0 Тогда
			Возврат;
		КонецЕсли;
		чВыбор = ?(чВыбор = 1, 1, 0);
	КонецЕсли;

	Если чФлаг = 1 Тогда
		сзВыбор.УдалитьВсе();
		СписокМетаданных("Справочник", сзВыбор, 1, чВыбор);
		СписокМетаданных("Документ", сзВыбор, 1, чВыбор);
		СписокМетаданных("Перечисление", сзВыбор, 1, чВыбор);
		Если чВыбор = 1 Тогда
			сзВыбор.ДобавитьЗначение("Счет", "<<СЧЕТ>>");
		КонецЕсли;
		Для А = 1 По Метаданные.ПланСчетов() Цикл
			сзВыбор.ДобавитьЗначение("Счет." + Метаданные.ПланСчетов(А).Идентификатор);
		КонецЦикла;
		Если чВыбор = 1 Тогда
			сзВыбор.ДобавитьЗначение("ПланСчетов", "<<ПЛАН СЧЕТОВ>>");
			сзВыбор.ДобавитьЗначение("ВидСубконто", "<<ВИД СУБКОНТО>>");
			сзВыбор.ДобавитьЗначение("Календарь", "<<КАЛЕНДАРЬ>>");
			сзВыбор.ДобавитьЗначение("ВидРасчета", "<<ВИД РАСЧЕТА>>");
		Иначе
			СписокМетаданных("ПланСчетов", сзВыбор, 0, чВыбор);
			СписокМетаданных("ВидСубконто", сзВыбор, 0, чВыбор);
			СписокМетаданных("Календарь", сзВыбор, 0, чВыбор);
			СписокМетаданных("ВидРасчета", сзВыбор, 0, чВыбор);
		КонецЕсли;

		чПоз = 0;
		Если ?(чВыбор = 1, сзВыбор.ОтметитьЗначения(, "Виды объектов",, 0), сзВыбор.ВыбратьЗначение(, "Виды объектов", чПоз, 0, 0)) = 0 Тогда
			Возврат;
		КонецЕсли;

		Если чВыбор = 1 Тогда
			Для А = 1 По сзВыбор.РазмерСписка() Цикл
				Если сзВыбор.Пометка(А) = 1 Тогда
					стрВид = сзВыбор.ПолучитьЗначение(А);
					Если сзОбъекты.НайтиЗначение(стрВид) = 0 Тогда
						сзОбъекты.ДобавитьЗначение(стрВид);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		Иначе
			стрВид = сзВыбор.ПолучитьЗначение(чПоз);
			хзЗначение = ПолучитьПустоеЗначение(стрВид);
			Если ТипЗначения(хзЗначение) = 11 Тогда
				ОткрытьПодбор(стрВид,, хзКонт, 1);
				Если ТипЗначения(хзКонт) = 100 Тогда
					хзКонт.ВыборГруппы(1)
				КонецЕсли;
			ИначеЕсли ТипЗначения(хзЗначение) = 12 Тогда
				ОткрытьПодбор(стрВид,, хзКонт, 1);
			Иначе
				Если ВвестиЗначение(хзЗначение, "Выберите объект", стрВид) = 1 Тогда
					Если сзОбъекты.НайтиЗначение(хзЗначение) = 0 Тогда
						сзОбъекты.ДобавитьЗначение(хзЗначение);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли чФлаг = 2 Тогда
		чПоз = сзОбъекты.ТекущаяСтрока();
		Если чПоз > 0 Тогда
			сзОбъекты.УдалитьЗначение(чПоз, 1);
			Если сзОбъекты.РазмерСписка() > 0 Тогда
				сзОбъекты.ТекущаяСтрока(Мин(сзОбъекты.РазмерСписка(), чПоз));
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли чФлаг = 3 Тогда
		Для А = - сзОбъекты.РазмерСписка() По - 1 Цикл
			хзЗначение = сзОбъекты.ПолучитьЗначение( - А);
			Если ТипЗначения(хзЗначение) = 2 Тогда
				Если чВыбор = 1 Тогда
					сзОбъекты.УдалитьЗначение( - А, 1);
				КонецЕсли;
			ИначеЕсли чВыбор = 0 Тогда
				сзОбъекты.УдалитьЗначение( - А, 1);
			КонецЕсли;
		КонецЦикла;
		Если сзОбъекты.РазмерСписка() > 0 Тогда
			сзОбъекты.ТекущаяСтрока(1);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ОбработкаПодбора(хзОбъект, Конт)
	Если сзОбъекты.НайтиЗначение(хзОбъект) = 0 Тогда
		сзОбъекты.ДобавитьЗначение(хзОбъект);
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура Глубина()
	сзВыбор = СоздатьОбъект("СписокЗначений");
	сзВыбор.ДобавитьЗначение("Показать");
	сзВыбор.ДобавитьЗначение("Изменить");
	А = 0;
	Если сзВыбор.ВыбратьЗначение(,, А, 0, 1) = 0 Тогда
		Возврат;
	КонецЕсли;
	Если А = 1 Тогда
		Сообщить("Глубина просмотра: " + гТабличноеПоле.ПоставщикДанных.ГлубинаПросмотра);
	Иначе
		А = гТабличноеПоле.ПоставщикДанных.ГлубинаПросмотра;
		Если ВвестиЧисло(А, "Новая глубина", 7, 0, 0) = 1 Тогда
			гТабличноеПоле.ПоставщикДанных.УстановитьГлубину(А);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ИзменитьФильтр()
	Перем сзСоб, стрТипСобытия;

	ПоказатьСобытия(1);

	гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр();

	чВсеТипы = 0;
	Для А = 1 По сзТипыСобытий.РазмерСписка() Цикл
		Если сзТипыСобытий.Пометка(А) = 0 Тогда
			Продолжить;
		КонецЕсли;
		чВсеТипы = чВсеТипы + 1;
		стрТипСобытия = "";
		сзСоб = сзТипыСобытий.ПолучитьЗначение(А, стрТипСобытия).Получить("События");
		чВсе = 0;
		Для Б = 1 По сзСоб.РазмерСписка() Цикл
			чВсе = чВсе + ?(сзСоб.Пометка(Б) = 0, 0, 1);
		КонецЦикла;
		Если чВсе = сзСоб.РазмерСписка() Тогда
			чТип = сзТипыСобытий.ПолучитьЗначение(А).Получить("Тип");
			Если А > гМаксТипСобытия1С Тогда
				гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(чТип, стрТипСобытия);
			Иначе
				гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(чТип);
			КонецЕсли;
		Иначе
			Для Б = 1 По сзСоб.РазмерСписка() Цикл
				Если сзСоб.Пометка(Б) = 0 Тогда
					Продолжить;
				КонецЕсли;
				стрСоб = "";
				чТип = сзСоб.ПолучитьЗначение(Б, стрСоб);
				Если чТип = 137 Тогда
					гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(чТип, стрСоб);
				Иначе
					гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(чТип);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	Если чВсеТипы = сзТипыСобытий.РазмерСписка() Тогда
		гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр();
	КонецЕсли;
	Если сзПользователи.РазмерСписка() > 0 Тогда
		гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(1, сзПользователи);
	КонецЕсли;
	стрРежим = "";
	Если Предприятие = 1 Тогда
		стрРежим = стрРежим + "e";
	КонецЕсли;
	Если Конфигуратор = 1 Тогда
		стрРежим = стрРежим + "c";
	КонецЕсли;
	Если Монитор = 1 Тогда
		стрРежим = стрРежим + "m";
	КонецЕсли;
	Если Отладчик = 1 Тогда
		стрРежим = стрРежим + "d";
	КонецЕсли;
	Если (ПустаяСтрока(стрРежим) = 0) И (стрРежим <> "ecmd") Тогда
		гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(2, стрРежим);
	КонецЕсли;
	стрКатегория = "";
	Если Сеанс = 1 Тогда
		стрКатегория = стрКатегория + "0";
	КонецЕсли;
	Если Административное = 1 Тогда
		стрКатегория = стрКатегория + "1";
	КонецЕсли;
	Если ИзменениеДанных = 1 Тогда
		стрКатегория = стрКатегория + "2";
	КонецЕсли;
	Если Информация = 1 Тогда
		стрКатегория = стрКатегория + "3";
	КонецЕсли;
	Если Варнинг = 1 Тогда
		стрКатегория = стрКатегория + "4";
	КонецЕсли;
	Если Ошибка = 1 Тогда
		стрКатегория = стрКатегория + "5";
	КонецЕсли;
	Если (ПустаяСтрока(стрКатегория) = 0) И (стрКатегория <> "012345") Тогда
		гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(3, стрКатегория);
	КонецЕсли;
	Если ПустаяСтрока(ФильтрКомментарий) = 0 Тогда
		гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(139, СокрЛП(ФильтрКомментарий));
	КонецЕсли;
	Для А = 1 По сзОбъекты.РазмерСписка() Цикл
		хзЗначение = сзОбъекты.ПолучитьЗначение(А);
		гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(?(ТипЗначения(хзЗначение) = 2, 140, 141), хзЗначение);
	КонецЦикла;
	Если ПустаяСтрока(ФильтрПредставление) = 0 Тогда
		гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр(142, СокрЛП(ФильтрПредставление));
	КонецЕсли;

	Если гТабличноеПоле.ПоставщикДанных.УстановитьФильтр(ИспользоватьБуфер) = 1 Тогда
		хзОбъект = ПолучитьПустоеЗначение();
		Сообщить("Изменения фильтра приняты.", "i");
	Иначе
		Сообщить("Изменения фильтра не приняты.", "!");
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ВыборкаСтрок()
	Перем ЛогПр, ДатаНач, ДатаКон, А;
	ДатаНач = гТабличноеПоле.ПоставщикДанных.НачалоПериода;
	ДатаКон = гТабличноеПоле.ПоставщикДанных.КонецПериода;
	ЛогПр = СоздатьОбъект("ПоставщикДанныхЖурналРегистрации");
	Если бЕстьИмяФайла = 1 Тогда
		ЛогПр.ИмяФайла = ИмяФайла;
	КонецЕсли;
	ЛогПр.ОткрытьФайл();
	Если (ДатаНач <> Дата(0)) ИЛИ (ДатаКон <> Дата(0)) Тогда
		ЛогПр.УстановитьПериод(ДатаНач, ДатаКон);
	КонецЕсли;
	Если ЛогПр.ВыбратьСтроки() = 1 Тогда
		стрРазделитель = "--------------------------------------------------";
		стрШаблон = "Позиция      : [ЛогПр.Позиция]
		|Дата         : [Формат(ЛогПр.Дата,""DДДММГГГГ"")]
		|Время        : [ЛогПр.Время]
		|Пользователь : [ЛогПр.Пользователь]
		|Режим        : [ЛогПр.Режим]
		|Тип события  : [?(ТипЗначения(ЛогПр.ТипСобытия)=100,ЛогПр.ТипСобытия.Идентификатор,ЛогПр.ТипСобытия)]
		|Событие      : [?(ТипЗначения(ЛогПр.Событие)=100,ЛогПр.Событие.Идентификатор,ЛогПр.Событие)]
		|Категория    : [ЛогПр.Категория]
		|Комментарий  : [Лев(ЛогПр.Комментарий,100)]
		|Объект       : [ЛогПр.Объект]
		|Представление: [ЛогПр.ПредставлениеОбъекта]
		|[стрРазделитель]";
		Сообщить("Выборка первых 10 строк с " + ?(ДатаНач = Дата(0), "начала журнала", Формат(ДатаНач, "DДДММГГГГ")) + " по " + ?(ДатаКон = Дата(0), "конец журнала", Формат(ДатаКон, "DДДММГГГГ")), "i");
		Сообщить(стрРазделитель);
		Для А = 1 По 10 Цикл
			Если ЛогПр.ПолучитьСтроку() = 1 Тогда
				Сообщить(Шаблон(стрШаблон));
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	ЛогПр.ЗакрытьФайл();
	Попытка
		Сообщить("Попытка доступа к свойствам провайдера, используемого в качестве поставщика данных ТП.", "i");
		А = гТабличноеПоле.ПоставщикДанных.Позиция;
	Исключение
		Сообщить("Поймали исключение: " + ОписаниеОшибки(), "!");
	КонецПопытки;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ПолучитьРисунок(Картинка, чРежим)
	Если чРежим = 1 Тогда
		гКартинкаРежимов = Картинка;
	ИначеЕсли чРежим = 2 Тогда
		гКартинкаКатегорий = Картинка;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура СообщитьТекСтроку()
	Перем хзТекСтр;
	хзТекСтр = гТабличноеПоле.ТекущаяСтрока;
	Если Врег(ТипЗначенияСтр(хзТекСтр)) = "СТРУКТУРА" Тогда
		Сообщить("Позиция текущей строки: " + СокрЛП(хзТекСтр.Позиция), "i");
	Иначе
		Сообщить("Позиция текущей строки: " + СокрЛП(хзТекСтр), "i");
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура УстановитьТекСтроку()
	чПоз = гТабличноеПоле.ТекущаяСтрока;
	Если ВвестиЧисло(чПоз, "Позиция", 10, 0, 0) = 1 Тогда
		гТабличноеПоле.ТекущаяСтрока = чПоз;
	КонецЕсли;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ИспользоватьЛогИБ()
	гТабличноеПоле.ПоставщикДанных.ИмяФайла = "";
	ИмяФайла = гТабличноеПоле.ПоставщикДанных.ИмяФайла;
	ЗаполнитьТипыСобытий();
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура СброситьФильтр()
	гТабличноеПоле.ПоставщикДанных.ИзменитьФильтр();
	гТабличноеПоле.ПоставщикДанных.УстановитьФильтр();
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура ПросмотрАрхивовПриИзменении()
	гТабличноеПоле.ПоставщикДанных.ПросмотрАрхивов = ПросмотрАрхивов;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
Процедура СообщитьОтбор()
	Перем Отбор, ЭлемОтбора, ЗначОтбора, стрЗнач;
	Отбор = гТабличноеПоле.ПоставщикДанных.Отбор;
	Сообщить("Количество элементов отбора: " + Отбор.Количество(), "i");
	Для А = 0 По Отбор.Количество() - 1 Цикл
		ЭлемОтбора = Отбор.Получить(А);
		ЗначОтбора = ЭлемОтбора.Значение;
		стрЗнач = Врег(ТипЗначенияСтр(ЗначОтбора));
		Если (стрЗнач = "СОБЫТИЕЖУРНАЛАРЕГИСТРАЦИИ") ИЛИ (стрЗнач = "ТИПСОБЫТИЯЖУРНАЛАРЕГИСТРАЦИИ") Тогда
			стрЗнач = ЗначОтбора.Идентификатор;
		Иначе
			стрЗнач = СокрЛП(ЗначОтбора);
		КонецЕсли;
		Если (ЭлемОтбора.Тип = 8) ИЛИ (ЭлемОтбора.Тип = 10) Тогда
			стрЗнач = " содержит " + стрЗнач;
		Иначе
			стрЗнач = " = " + стрЗнач;
		КонецЕсли;
		Сообщить("" + ЭлемОтбора.Имя + стрЗнач);
	КонецЦикла;
КонецПроцедуры

// ----------------------------------------------------------------------------------------------------
гМаксТипСобытия1С = 99999;
гТекСтрокаТипСобытия = 0;
бПериодУстановлен = 0;
бЕстьИмяФайла = 0;
