//======================================================================

Перем ИсходнаяТЗ;
Перем ТолькоПросмотр, ФормаДляВыбора, ВозвращатьСписок;
Перем ОбработкаВыбора, ОбработкаВыбора_Отчет, ОбработкаВыбора_Параметры;
Перем ФиксСтрок, ФиксКолонок;
Перем Путь;
Перем СпФункции;
Перем ТЗ_Фильтр, ТЗ_РеквизитыФильтра; //Для запоминания параметров фильтра
Перем НастройкиПечати, НастройкиЗагрузкиExcel;

Перем КонтекстПодбора; //Пока открыт подбор ТипЗначения(КонтекстПодбора) = 100
Перем СтрокаПодбора;   //Строка, для которой открыт подбор
Перем КолонкаПодбора;  //Колонка, для которой открыт подбор

Перем ПрограммныйКод; //Программа, которая выполнется для каждой строки

Перем GhostLoaded, localGhost, GM_GhostVariableName;
Перем VK_INSERT, VK_DELETE, VK_F1, VK_F4, VK_F5, VK_F9, VK_LSHIFT, VK_RSHIFT;
Перем VK_LEFT, VK_UP, VK_RIGHT, VK_DOWN;


//_____________________________________________________________________________
Процедура ТЗВФайл(ТЗ, Файл, Прогресс=1) Далее
Функция ТЗИзФайла(Файл, НомерСтроки=1, _Стр_=0) Далее

Процедура ЗаписатьТЗВФайл(ТЗ, ИмяФайла, ФорматФайла) Далее
Процедура СчитатьИзФайла() Далее

Функция ВыбраннуюПозициюВСписок(Сп) Далее
Процедура ОК() Далее
//_____________________________________________________________________________


//_____________________________________________________________________________
Функция ОткрытьОбработку(Обработка, Параметры, Модально, ВОтдельномОкне = 0)
	Перем Путь, Тип;
	
	РасположениеФайла(Путь,);
	Если ПустаяСтрока(Путь)=1 Тогда
		Если Метаданные.Обработка(Обработка).Выбран()=1 Тогда
			Тип = "Обработка";
		ИначеЕсли Метаданные.Отчет(Обработка).Выбран()=1 Тогда
			Тип = "Отчет";
		Иначе
			Тип = "ВнешнийОтчет";
		КонецЕсли;
	Иначе
		Тип = "ВнешнийОтчет";
	КонецЕсли;
	
	Если Тип="ВнешнийОтчет" Тогда
		Если ФС.СуществуетФайл(Путь+Обработка+".ert")=1 Тогда
			Путь = Путь+Обработка+".ert";
		ИначеЕсли ФС.СуществуетФайл(КаталогИБ()+Обработка+".ert")=1 Тогда
			Путь = КаталогИБ()+Обработка+".ert";
		ИначеЕсли ФС.СуществуетФайл(КаталогИБ()+"ExtForms\"+Обработка+".ert")=1 Тогда
			Путь = КаталогИБ()+"ExtForms\"+Обработка+".ert";
		Иначе
			Сообщить("Не найдена обработка '"+Обработка+"'", "!");
			Возврат 0;
		КонецЕсли;
		
		Отчет = "Отчет";
		Если ВОтдельномОкне = 1 Тогда
			Отчет = Отчет + "#";
		КонецЕсли;
		Если Модально=0 Тогда
			Возврат ОткрытьФорму(Отчет, Параметры, Путь);
		Иначе
			Возврат ОткрытьФормуМодально(Отчет, Параметры, Путь);
		КонецЕсли;
	Иначе
		Отчет = Тип+"."+Обработка;
		Если ВОтдельномОкне = 1 Тогда
			Отчет = Отчет + "#";
		КонецЕсли;
		Если Модально=0 Тогда
			Возврат ОткрытьФорму(Отчет, Параметры);
		Иначе
			Возврат ОткрытьФормуМодально(Отчет, Параметры);
		КонецЕсли;
	КонецЕсли;
КонецФункции

//_____________________________________________________________________________
Функция НомерТекущейКолонки()
	Перем ИмяКол, НомерКол;
	Попытка
		ИмяКол = ТЗ.ТекущаяКолонка(, НомерКол);
		Возврат НомерКол;
	Исключение
	КонецПопытки;
	Возврат 0;
КонецФункции

//_____________________________________________________________________________
Функция Инфо()
	Зн = "";
	ИмяКолонки = "";
	Попытка
		Кол = НомерТекущейКолонки();
		ИмяКолонки = ТЗ.ТекущаяКолонка();
		Зн = ТЗ.ПолучитьЗначение(ТЗ.НомерСтроки, Кол);
	Исключение
	КонецПопытки;
	
	Попытка
		Итог = ТЗ.Итог(Кол);
		Итог = "  Итог = "+Формат(Итог, "Ч.2.,");
	Исключение
		Итог = "";
	КонецПопытки;
	
	Возврат ""+ТЗ.НомерСтроки+"/"+ИмяКолонки+"  = "+Зн+Итог;
КонецФункции

//_____________________________________________________________________________
Процедура Закрепить()
	Перем Стр, Кол;
	
	Если (ФиксСтрок+ФиксКолонок) = 0 Тогда
		Кол = НомерТекущейКолонки();
		Если Кол <= 1 Тогда
			Активизировать("ТЗ");
			Возврат;
		КонецЕсли;
		ФиксСтрок = Макс(ТЗ.НомерСтроки-1, 0);
		ФиксКолонок = Макс(Кол-1, 0);
	Иначе
		ФиксСтрок = 0;
		ФиксКолонок = 0;
	КонецЕсли;

	ТЗ.Фиксировать(ФиксСтрок, ФиксКолонок);
	
	Если (ФиксСтрок+ФиксКолонок) = 0 Тогда
		Форма.КнЗакрепить.Заголовок("Закрепить");
	Иначе
		Форма.КнЗакрепить.Заголовок("Снять закрепление");
	КонецЕсли;

	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура ДобавитьСтроку(ДелатьКопию=0)
	Перем н1, н2, н, З;

	Если ФормаДляВыбора = 1 Тогда Возврат; КонецЕсли;	
	
	н1 = ТЗ.НомерСтроки;
	Если ТЗ.НомерСтроки=0 Тогда
		ТЗ.НоваяСтрока();
	Иначе
		ТЗ.НоваяСтрока(ТЗ.НомерСтроки);
		н1 = н1 + 1;
	КонецЕсли;
	н2 = ТЗ.НомерСтроки;
	
	Если (н1<>0) И (н2<>0) И (ДелатьКопию<>0) Тогда
		Для н=1 По ТЗ.КоличествоКолонок() Цикл
			З = ТЗ.ПолучитьЗначение(н1, н);
			ТЗ.УстановитьЗначение(н2, н, З);
		КонецЦикла;
	КонецЕсли;

	Попытка
		ТЗ.ТекущаяСтрока(н2);
	Исключение
	КонецПопытки;

	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура УдалитьСтроку()
	Если ФормаДляВыбора = 1 Тогда Возврат; КонецЕсли;	
	Если ТЗ.НомерСтроки=0 Тогда Возврат; КонецЕсли;
	
	н = ТЗ.НомерСтроки;
	ТЗ.УдалитьСтроку(н);
	
	Попытка
		ТЗ.ПолучитьСтрокуПоНомеру(н);
	Исключение
		Попытка
			ТЗ.ПолучитьСтрокуПоНомеру(н-1);
		Исключение
		КонецПопытки;
	КонецПопытки;
	
	Попытка
		ТЗ.ТекущаяСтрока(ТЗ.НомерСтроки);
	Исключение
	КонецПопытки;

	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Функция ПереместитьСтроку(Шаг, Цикличность = 1)
	Перем НомерСтроки, НовыйНомер;
	
	Если ФормаДляВыбора = 1 Тогда Возврат ТЗ.ТекущаяСтрока(); КонецЕсли;	

	НомерСтроки = ТЗ.ТекущаяСтрока();
	Если ТЗ.КоличествоСтрок() <= 1 Тогда Возврат НомерСтроки; КонецЕсли;
	
	НовыйНомер = НомерСтроки + Шаг;
	Если НовыйНомер < 1 Тогда
		Если Цикличность <> 1 Тогда
			Перейти ~Выход;
		КонецЕсли;
		НовыйНомер = ТЗ.КоличествоСтрок();
	ИначеЕсли НовыйНомер > ТЗ.КоличествоСтрок() Тогда
		Если Цикличность <> 1 Тогда
			Перейти ~Выход;
		КонецЕсли;
		НовыйНомер = 1;
	КонецЕсли;
	
	ТЗ.СдвинутьСтроку(НовыйНомер - НомерСтроки);
	ТЗ.ТекущаяСтрока(НовыйНомер);
	ТЗ.ПолучитьСтрокуПоНомеру(НовыйНомер);
	
~Выход:
	Активизировать("ТЗ");
	Возврат ТЗ.ТекущаяСтрока();
КонецФункции

//_____________________________________________________________________________
Процедура ДобавитьКолонку(ДелатьКопию=0)
	Если ФормаДляВыбора = 1 Тогда Возврат; КонецЕсли;	

	Сп = СоздатьОбъект("СписокЗначений");
	Сп.Установить("ТЗ", ТЗ);
	Сп.Установить("НоваяКолонка", 1);
	Если (ДелатьКопию = 1) И (НомерТекущейКолонки() > 0) Тогда
		Сп.Установить("Колонка", НомерТекущейКолонки());
	КонецЕсли;

	Парам = Сп;
	ОткрытьОбработку("РеквизитыКолонкиТЗ", Парам, 1);
	Попытка
		ТЗ.ТекущаяКолонка(Сп.Получить("Колонка"));
	Исключение
	КонецПопытки;
	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура РедактироватьКолонку()
	Если ФормаДляВыбора = 1 Тогда Возврат; КонецЕсли;	

	Если НомерТекущейКолонки() > 0 Тогда
		Сп = СоздатьОбъект("СписокЗначений");
		Сп.Установить("ТЗ", ТЗ);
		Сп.Установить("Колонка", НомерТекущейКолонки());
		Парам = Сп;
		ОткрытьОбработку("РеквизитыКолонкиТЗ", Парам, 1);
		Попытка
			ТЗ.ТекущаяКолонка(Сп.Получить("Колонка"));
		Исключение
		КонецПопытки;
	КонецЕсли;
КонецПроцедуры


//_____________________________________________________________________________
Процедура УдалитьКолонку()
	Если ФормаДляВыбора = 1 Тогда Возврат; КонецЕсли;	

	Попытка
		ТЗ.УдалитьКолонку(НомерТекущейКолонки());
	Исключение
	КонецПопытки;
	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура ПереместитьКолонку(Шаг = 1)
	Перем Колонка, Идентификатор, тзКолонка;
	Перем Тип, Длина, Точность, Заголовок, Ширина, ФорматКолонки, Положение;
	
	Если ФормаДляВыбора = 1 Тогда Возврат; КонецЕсли;	
	Если ТЗ.КоличествоКолонок() <= 1 Тогда Возврат; КонецЕсли;
	
	Идентификатор = ТЗ.ТекущаяКолонка(, Колонка);
	ТЗ.ПолучитьПараметрыКолонки(Колонка, Тип, Длина, Точность, Заголовок, Ширина, ФорматКолонки, Положение);
	
	НовыйНомер = Колонка + Шаг;
	Если НовыйНомер < 1 Тогда
		НовыйНомер = ТЗ.КоличествоКолонок();
	ИначеЕсли НовыйНомер > ТЗ.КоличествоКолонок() Тогда
		НовыйНомер = 1;
	КонецЕсли;
	
	тзКолонка = СоздатьОбъект("ТаблицаЗначений");
	ТЗ.Выгрузить(тзКолонка,,, Колонка);
	ТЗ.УдалитьКолонку(Колонка);
	ТЗ.ВставитьКолонку(Идентификатор, НовыйНомер, Тип, Длина, Точность, Заголовок, Ширина, ФорматКолонки, Положение);
	ТЗ.Заполнить(тзКолонка,,, НовыйНомер);
	ТЗ.ТекущаяКолонка(НовыйНомер);
	Активизировать("ТЗ");
КонецПроцедуры


//_____________________________________________________________________________
// - ТипПоиска: 1 - искать такой же, 2 - искать отличный
// - Направление: 1 - вниз, -1 - вверх
Процедура Следующий(ТипПоиска=1, Направление=1) 
	Перем Колонка, ТекЗнач, З, н, Найдено;
	
	Если ТЗ.ТекущаяСтрока()=0 Тогда
		Активизировать("ТЗ");
		Возврат;
	КонецЕсли;
	
	Колонка = НомерТекущейКолонки();
	ТекЗнач = ТЗ.ПолучитьЗначение(ТЗ.ТекущаяСтрока(), Колонка);
	Найдено = 0;
	
	н = ТЗ.ТекущаяСтрока();
	Продолжать = 1;
	
	Пока Продолжать=1 Цикл
		н = н + Направление;
		Если Направление>0 Тогда
			Продолжать = ?(н<=ТЗ.КоличествоСтрок(), 1, 0);
		Иначе
			Продолжать = ?(н>0, 1, 0);
		КонецЕсли;
		Если Продолжать=0 Тогда Прервать; КонецЕсли;

		З = ТЗ.ПолучитьЗначение(н, Колонка);
		Если ТипПоиска=2 Тогда
			Попытка
				Если ТекЗнач<>З Тогда
					Найдено = н;
					Прервать;
				КонецЕсли;
			Исключение
				Найдено = н;
				Прервать;
			КонецПопытки;
		Иначе
			Попытка
				Если ТекЗнач=З Тогда
					Найдено = н;
					Прервать;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
	Если Найдено>0 Тогда
		ТЗ.ПолучитьСтрокуПоНомеру(Найдено);
		ТЗ.ТекущаяСтрока(Найдено);
	КонецЕсли;
	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура ЗагрузитьТЗ()
	Перем н, Стр;
	Перем ФорматКолонки, Положение;
	
	
	Если ТипЗначенияСтр(ИсходнаяТЗ)="ТаблицаЗначений" Тогда
		ТЗ.Загрузить(ИсходнаяТЗ);
		
		Для н=1 По ИсходнаяТЗ.КоличествоКолонок() Цикл
			Имя = ИсходнаяТЗ.ПолучитьПараметрыКолонки(н,,,,,, ФорматКолонки, Положение);
			ТЗ.УстановитьПараметрыКолонки(н,,,,,, ФорматКолонки, Положение);
			ТЗ.ВидимостьКолонки(Имя, ИсходнаяТЗ.ВидимостьКолонки(Имя));
		КонецЦикла;
	
		ТЗ.ТекущаяСтрока(ИсходнаяТЗ.НомерСтроки);
		Попытка
			ТЗ.ТекущаяКолонка(ИсходнаяТЗ.ТекущаяКолонка());
		Исключение
		КонецПопытки;
	ИначеЕсли ТипЗначенияСтр(ИсходнаяТЗ)="ИндексированнаяТаблица" Тогда
		ИсходнаяТЗ.Выгрузить(ТЗ);
	ИначеЕсли ТипЗначенияСтр(ИсходнаяТЗ)="СписокЗначений" Тогда
		ТЗ.Очистить();
		ТЗ.НоваяКолонка("Строка", "Строка");
		ТЗ.НоваяКолонка("Значение");
		Для н=1 По ИсходнаяТЗ.РазмерСписка() Цикл
			ТЗ.НоваяСтрока();
			ТЗ.Значение = ИсходнаяТЗ.ПолучитьЗначение(н, Стр);
			ТЗ.Строка = Стр;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

//_____________________________________________________________________________
Процедура ВыгрузитьТЗ(Сохранять=0)
	Если ТипЗначенияСтр(ИсходнаяТЗ)="ТаблицаЗначений" Тогда
		Если Сохранять=1 Тогда
			ИсходнаяТЗ.Загрузить(ТЗ);
		КонецЕсли;
		ИсходнаяТЗ.ТекущаяСтрока(ТЗ.НомерСтроки);
		Если ТЗ.НомерСтроки>0 Тогда
			Попытка
				ИсходнаяТЗ.ПолучитьСтрокуПоНомеру(ТЗ.НомерСтроки);
			Исключение
			КонецПопытки;
		КонецЕсли;
	
		Попытка
			ИсходнаяТЗ.ТекущаяКолонка(НомерТекущейКолонки());
		Исключение
		КонецПопытки;
	ИначеЕсли ТипЗначенияСтр(ИсходнаяТЗ)="ИндексированнаяТаблица" Тогда
		Если Сохранять = 1 Тогда
			ИсходнаяТЗ.Загрузить(ТЗ);
		КонецЕсли;
	ИначеЕсли ТипЗначенияСтр(ИсходнаяТЗ)="СписокЗначений" Тогда
		Если Сохранять=1 Тогда
			ИсходнаяТЗ.УдалитьВсе();
			ТЗ.ВыбратьСтроки();
			Пока ТЗ.ПолучитьСтроку()=1 Цикл
				ИсходнаяТЗ.ДобавитьЗначение(ТЗ.Значение, ТЗ.Строка);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

//_____________________________________________________________________________
Процедура РедакторТЗ(Знач ТЗ, Заголовок="", Модально=0, Знач ВнешнийОтчет=0)
	Перем Путь, Сп;
	
	Сп = СоздатьОбъект("СписокЗначений");
	Сп.Установить("ТЗ", ТЗ);
	Сп.Установить("Заголовок", Заголовок);
	
	РасположениеФайла(Путь,);
	Если ПустаяСтрока(Путь) = 0 Тогда ВнешнийОтчет = 1; КонецЕсли;
	Если ВнешнийОтчет = 1 Тогда
		Если ФС.СуществуетФайл(Путь+"РедакторТЗ.ert") = 0 Тогда Путь = КаталогИБ()+"ExtForms\"; КонецЕсли;
		Если ФС.СуществуетФайл(Путь+"РедакторТЗ.ert") = 0 Тогда Путь = КаталогИБ(); КонецЕсли;
		Если ФС.СуществуетФайл(Путь+"РедакторТЗ.ert") = 0 Тогда ВнешнийОтчет = 0; КонецЕсли;
	КонецЕсли;
	
	
	Если Модально=0 Тогда
		Если ВнешнийОтчет = 0 Тогда
			ОткрытьФорму("Обработка.РедакторТЗ#", Сп);
		Иначе
			ОткрытьФорму("Отчет#", Сп, Путь+"РедакторТЗ.ert");
		КонецЕсли;
	Иначе
		Если ВнешнийОтчет = 0 Тогда
			ОткрытьФормуМодально("Обработка.РедакторТЗ#", Сп);
		Иначе
			ОткрытьФормуМодально("Отчет#", Сп, Путь+"РедакторТЗ.ert");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


//_____________________________________________________________________________
//_____________________________________________________________________________
Функция АльтернативнаяОбработкаВыбора(Режим)
	Если ПустоеЗначение(ОбработкаВыбора) = 0 Тогда //Альтернативная обработка выбора значения
		Сп = СоздатьОбъект("СписокЗначений");
		Сп.Установить("СтандартнаяОбработка", 1);
		Сп.Установить("Режим", Режим); //0 - doubleclick, 1 - нажатие кнопки редактирования на панели инструментов
		Сп.Установить("ОбработкаВыбораСтрокиТЗ", 1);
		Сп.Установить("Контекст", Контекст);
		Сп.Установить("ТЗ", ТЗ);
		Сп.Установить("Параметры", ОбработкаВыбора_Параметры);
		ВыбраннуюПозициюВСписок(Сп);

		Если ТипЗначения(ОбработкаВыбора) = 1 Тогда
			Форма.ВыполнитьВыбор(Сп);
		Иначе
			Парам = Сп;
			Если ОбработкаВыбора = "Отчет" Тогда
				ОткрытьФормуМодально(ОбработкаВыбора, Парам, ОбработкаВыбора_Отчет); //внешний отчет
			Иначе
				ОткрытьФормуМодально(ОбработкаВыбора, Парам); //всё остальное
			КонецЕсли;
		КонецЕсли;
		
		Активизировать("ТЗ");
		Если Число(Сп.Получить("СтандартнаяОбработка")) = 0 Тогда Возврат 1; КонецЕсли;
	КонецЕсли;
	
	Возврат 0;
КонецФункции

//_____________________________________________________________________________
Процедура АктивизироватьФормуПодбора()
	КонтекстПодбора.Активизировать("НомерДок", 0);
	КонтекстПодбора.Активизировать("ДатаДок", 0);
	КонтекстПодбора.Активизировать("Код", 0);
	КонтекстПодбора.Активизировать("Наименование", 0);
КонецПроцедуры

//_____________________________________________________________________________
Функция ВыбратьВидСправочника(Вид = "")
	Перем ВыбранныйВид;
	
	Сп = СоздатьОбъект("СписокЗначений");
	Для н = 1 По Метаданные.Справочник() Цикл
		МетаСпр = Метаданные.Справочник(н);
		Сп.ДобавитьЗначение(МетаСпр.Идентификатор, МетаСпр.Представление());
	КонецЦикла;
    
	ВыбранныйВид = Вид;
	Отв = Сп.ВыбратьЗначение(ВыбранныйВид, "Выберите вид справочника",,, 0);
	Возврат ВыбранныйВид;
КонецФункции

//_____________________________________________________________________________
Функция ВыбратьТип(Тип = "")
	Перем НовыйТип;
	
	СпТип = СоздатьОбъект("СписокЗначений");
	СпТип.ДобавитьЗначение("Число");
	СпТип.ДобавитьЗначение("Строка");
	СпТип.ДобавитьЗначение("Дата");
	СпТип.ДобавитьЗначение("ТаблицаЗначений");
	СпТип.ДобавитьЗначение("СписокЗначений");
	СпТип.ДобавитьЗначение("Справочник");
	СпТип.ДобавитьЗначение("Документ");
	СпТип.ДобавитьЗначение("Счет");
	Для н=1 По Метаданные.ПланСчетов() Цикл
		СпТип.ДобавитьЗначение("Счет." + Метаданные.ПланСчетов(н).Идентификатор);
	КонецЦикла;
	Для н=1 По Метаданные.Перечисление() Цикл
		СпТип.ДобавитьЗначение("Перечисление." + Метаданные.Перечисление(н).Идентификатор);
	КонецЦикла;

	НовыйТип = Тип;
	СпТип.ВыбратьЗначение(НовыйТип, "Выберите тип значения",,, 0);
	Возврат НовыйТип;
КонецФункции

//_____________________________________________________________________________
Процедура Подбор(нСтр, Колонка, Значение)
	Перем ИПравдаПодбор;
	
	СтрокаПодбора = нСтр;
	КолонкаПодбора = Колонка;
	Тип = ТипЗначенияСтр(Значение);
	Попытка
		Вид = Значение.Вид();
	Исключение
	КонецПопытки;

	ИПравдаПодбор = 1;
	Если (Форма.МодальныйРежим() = 1) ИЛИ (ТипЗначения(Значение) <= 3) ИЛИ (Тип = "Счет") Тогда
		ИПравдаПодбор = 0;
		ВвестиЗначение(Значение, Колонка);
	ИначеЕсли ТипЗначения(Значение) = 10 Тогда
		ИПравдаПодбор = 0;
		ВвестиПеречисление(Значение, Колонка);
	КонецЕсли;
	Если ИПравдаПодбор = 0 Тогда
		ТЗ.УстановитьЗначение(нСтр, Колонка, Значение);
		Активизировать("ТЗ");
		Возврат;
	КонецЕсли;
	
	
	Если ТипЗначения(КонтекстПодбора) = 100 Тогда
		Предупреждение("Предыдущий подбор не закрыт.");
		АктивизироватьФормуПодбора();
		Возврат;
	КонецЕсли;

	Если (ПустаяСтрока(Вид) = 1) И (Тип = "Справочник") Тогда
		Вид = ВыбратьВидСправочника(Вид);
		Если ПустаяСтрока(Вид) = 1 Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если (Тип = "Документ") И (ПустаяСтрока(Вид) = 1) Тогда
		Журнал = "Журнал." + Метаданные.ПолныйЖурнал.Идентификатор;
		ОткрытьПодбор(Журнал,, КонтекстПодбора, 0, Значение);
	Иначе
		ОткрытьПодбор(Тип+"."+Вид,, КонтекстПодбора, 0, Значение);
		Если Тип = "Справочник" Тогда
			КонтекстПодбора.ВыборГруппы(1);
			Попытка
				КонтекстПодбора.ИспользоватьВладельца(Значение.Владелец, 1);
				КонтекстПодбора.АктивизироватьОбъект(Значение);
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


//_____________________________________________________________________________
Процедура ОбработкаПодбора(Объект, Конт)
	ТЗ.УстановитьЗначение(СтрокаПодбора, КолонкаПодбора, Объект);
КонецПроцедуры

//_____________________________________________________________________________
// - Режим - 0 - выбор значения, 1 - редактирование значение (для справочников открывается форма элемента, и т.д.)
Процедура Редактор(Режим = 0)
	Перем Длина, Точность;
	
	Если ТЗ.КоличествоСтрок() = 0 Тогда
		Возврат;
	ИначеЕсли ТЗ.КоличествоКолонок() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ФормаДляВыбора = 1 Тогда
		ОК();
		Возврат;
	КонецЕсли;
	
	Если АльтернативнаяОбработкаВыбора(Режим) = 1 Тогда
		Возврат;
	КонецЕсли;
	
	Если ТолькоПросмотр = 1 Тогда
		Возврат;
	КонецЕсли;

	Стр = ТЗ.ТекущаяСтрока();
	Кол = НомерТекущейКолонки();
	ИмяКолонки = ТЗ.ТекущаяКолонка();
	Значение = ТЗ.ПолучитьЗначение(Стр, Кол);
	
	Тип = ТипЗначенияСтр(Значение);
	Если (Тип="") ИЛИ (Тип="Неопределённый") Тогда
		Тип = ВыбратьТип();
		Если (Тип = "ТаблицаЗначений") ИЛИ (Тип = "СписокЗначений") Тогда
			НовЗнач = СоздатьОбъект(Тип);
		Иначе
			НовЗнач = ПолучитьПустоеЗначение(Тип);
		КонецЕсли;
		ТЗ.УстановитьЗначение(Стр, Кол, НовЗнач);
		Если ПустаяСтрока(Тип) = 0 Тогда
			Редактор(Режим);
			Возврат;
		КонецЕсли;
	ИначеЕсли Тип="Строка" Тогда
		Если GhostLoaded = 1 Тогда
			localGhost.ВвестиСтрокуВЯчейке(1, Значение, 255);
		Иначе
			ВвестиСтроку(Значение, ИмяКолонки, 255);
		КонецЕсли;
	ИначеЕсли Тип="Число" Тогда
		Длина = 0; Точность = 0;
		ТЗ.ПолучитьПараметрыКолонки(Кол,, Длина, Точность);
		Если Длина = 0 Тогда Длина = 64; КонецЕсли;
		Если Точность = 0 Тогда Точность = 4; Длина = Длина + 5; КонецЕсли;
		Если GhostLoaded = 1 Тогда
			localGhost.ВвестиЧислоВЯчейке(1, Значение, Длина, Точность);
		Иначе
			ВвестиЧисло(Значение, ИмяКолонки, Длина, Точность);
		КонецЕсли;
	ИначеЕсли Тип="Дата" Тогда
		Если GhostLoaded = 1 Тогда
			localGhost.ВвестиДатуВЯчейке(1, Значение);
		Иначе
			ВвестиДату(Значение, ИмяКолонки);
		КонецЕсли;
	ИначеЕсли Тип="Перечисление" Тогда
		ВвестиПеречисление(Значение, ИмяКолонки);
	ИначеЕсли Тип="ТаблицаЗначений" Тогда
		РедакторТЗ(Значение, ИмяКолонки, Форма.МодальныйРежим());
		Возврат;
	ИначеЕсли Тип="Общие.ТаблицаЗначений" Тогда
		РедакторТЗ(Значение.ТЗ(), ИмяКолонки, Форма.МодальныйРежим());
		Возврат;
	ИначеЕсли Тип="ИндексированнаяТаблица" Тогда
		РедакторТЗ(Значение, ИмяКолонки, Форма.МодальныйРежим());
		Возврат;
	ИначеЕсли Тип="СписокЗначений" Тогда
		РедакторТЗ(Значение, ИмяКолонки, Форма.МодальныйРежим());
		Возврат;
	ИначеЕсли Тип="DynaValue" Тогда
		сзЗначение = СоздатьОбъект("СписокЗначений");
		Значение.СвойстваВСписокЗначений(сзЗначение);
		РедакторТЗ(сзЗначение, ИмяКолонки, Форма.МодальныйРежим());
		Возврат;
	Иначе
		Если Режим = 1 Тогда
			Если Тип = "Справочник" Тогда
				Значение = Значение.ТекущийЭлемент();
			ИначеЕсли Тип = "Документ" Тогда
				Значение = Значение.ТекущийДокумент();
			КонецЕсли;
			Попытка
				ОткрытьФорму(Значение);
				Возврат;
			Исключение
				Подбор(Стр, Кол, Значение);
			КонецПопытки;
		Иначе
			Подбор(Стр, Кол, Значение);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	ТЗ.УстановитьЗначение(Стр, Кол, Значение);
	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура EditRekv()
	Если ТолькоПросмотр = 1 Тогда Возврат; КонецЕсли;
	
	Стр = ТЗ.ТекущаяСтрока();
	Кол = НомерТекущейКолонки();
	Значение = ТЗ.ПолучитьЗначение(Стр, Кол);
	Если (ТипЗначения(Значение) = 11) ИЛИ (ТипЗначения(Значение) = 12) Тогда
		ОткрытьОбработку("editrekv", Значение, 0, 1);
	Иначе
	КонецЕсли;
	//Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура ОчиститьЗначение()
	Стр = ТЗ.ТекущаяСтрока();
	Кол = НомерТекущейКолонки();
	ТЗ.УстановитьЗначение(Стр, Кол, ПолучитьПустоеЗначение());
	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура ОбработкаВнешнегоСобытия(Источник, Событие, Данные)
	Если Источник = "GhostService" Тогда
		Если Событие="RButtonUp" Тогда
			Сп=СоздатьОбъект("СписокЗначений");
			Сп.ДобавитьЗначение(1,"Вставить строку");
			Сп.ДобавитьЗначение(2,"Скопировать строку");
			Сп.ДобавитьЗначение(3,"Удалить строку");
			Сп.ДобавитьЗначение(4,"Выбрать значение ячейки");
			Сп.ДобавитьЗначение(5,"Редактировать значение ячейки");
			Действие = "";
			Если Сп.ВыбратьЗначение(Действие,,,,1) = 1 Тогда
				Если Действие = 1 Тогда
					ДобавитьСтроку();
				ИначеЕсли Действие = 2 Тогда
					ДобавитьСтроку(1);
				ИначеЕсли Действие = 3 Тогда
					УдалитьСтроку();
				ИначеЕсли Действие = 4 Тогда
					Редактор();
				ИначеЕсли Действие = 5 Тогда
					Редактор(1);
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли Событие = "KeyPress" Тогда
			Если Число(Данные) = VK_UP Тогда
				Следующий(2, -1);
			ИначеЕсли Число(Данные) = VK_DOWN Тогда
				Следующий(2, 1);
			ИначеЕсли Число(Данные) = VK_LEFT Тогда
				ПереместитьКолонку(-1);
			ИначеЕсли Число(Данные) = VK_RIGHT Тогда
				ПереместитьКолонку(1);
			ИначеЕсли Число(Данные) = VK_INSERT Тогда
				ДобавитьСтроку();
			ИначеЕсли Число(Данные) = VK_F1 Тогда
				Сообщить("Редактор ТЗ неизвестной версии.");
				Сообщить("Автор - Диркс Алексей, город Новосибирск.");
			ИначеЕсли Число(Данные) = VK_F5 Тогда
				ДобавитьСтроку(1);
			ИначеЕсли Число(Данные) = VK_F9 Тогда
				ДобавитьСтроку(1);
			ИначеЕсли Число(Данные) = VK_DELETE Тогда
				УдалитьСтроку();
			ИначеЕсли Число(Данные) = VK_F4 Тогда
				Редактор(1);
			ИначеЕсли Число(Данные) = КодСимв("S") Тогда
				ЗаписатьТЗВФайл(ТЗ,, 3);
			ИначеЕсли Число(Данные) = КодСимв("O") Тогда
				СчитатьИзФайла();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

//_____________________________________________________________________________
Функция ActivateGhostService(ПриОткрытии = 0)
	//Попробуем зацепиться за GhostService. Объект GhostService должен 
	//быть создан 1 раз при старте системы, и записан в гл. переменную. 
	//Примерно так:
	//	ЗагрузитьВнешнююКомпоненту("Ghost.dll");
	//	Ghost = СоздатьОбъект("AddIn.GhostService");
	
	//Здесь предполагается, что глобальная переменная называется Ghost. Если у вас 
	//она называется по другому, то нужно слегка подправить нижеследующий код.
	
	GhostLoaded = 0;
	//Если ФС.СуществуетФайл(КаталогИБ()+"ghost.dll") = 1 Тогда //не вполне корректно, но тех, кто ghost не использует упасёт от лишних заморочек
		Попытка
			Если ПустаяСтрока(GM_GhostVariableName) = 1 Тогда
				GM_GhostVariableName = "Ghost";
			КонецЕсли;
			Шаблон("[Присвоить(localGhost, "+GM_GhostVariableName+")]"); //Это извращение нужно, чтобы можно было задать имя переменной из глобального модуля
			Если ПриОткрытии = 1 Тогда
				localGhost.ЛовитьТаблицу(16, 1);
			Иначе
				localGhost.ПойматьТаблицу(16, 1);
			КонецЕсли;
			//localGhost.РегистрироватьКлавишу(VK_LEFT, 0, 1, 0);
			//localGhost.РегистрироватьКлавишу(VK_UP, 0, 1, 0);
			//localGhost.РегистрироватьКлавишу(VK_RIGHT, 0, 1, 0);
			//localGhost.РегистрироватьКлавишу(VK_DOWN, 0, 1, 0);
			
			//localGhost.РегистрироватьКлавишу(VK_INSERT);
			//localGhost.РегистрироватьКлавишу(VK_DELETE);
			//localGhost.РегистрироватьКлавишу(VK_F1);
			//localGhost.РегистрироватьКлавишу(VK_F4);
			localGhost.РегистрироватьКлавишу(VK_F5);
			//localGhost.РегистрироватьКлавишу(VK_F9);
			
			//localGhost.РегистрироватьКлавишу(КодСимв("S"), 0, 1, 0);
			//localGhost.РегистрироватьКлавишу(КодСимв("O"), 0, 1, 0);
			GhostLoaded = 1;
		Исключение
			Возврат 0;
		КонецПопытки;
	//КонецЕсли;
	
	Возврат 1;
КонецФункции

//_____________________________________________________________________________
Функция DeactivateGhostService()
	Если GhostLoaded = 1 Тогда
		Рез = localGhost.ОтпуститьТаблицу();
		Если Рез = 1 Тогда
			GhostLoaded = 0;
		КонецЕсли;
	КонецЕсли;
	Возврат 1;
КонецФункции

//_____________________________________________________________________________
Процедура OnChange_FUseGhostService()
	Если FUseGhostService = 1 Тогда
		FUseGhostService = ActivateGhostService();
		Если FUseGhostService = 0 Тогда
			Отв = ВвестиСтроку(GM_GhostVariableName, "Введите название глобальной переменной, содержащей объект GhostService", 255);
			Если Отв = 1 Тогда
				FUseGhostService = ActivateGhostService();
			КонецЕсли;
		КонецЕсли;
		
	Иначе
		Если GhostLoaded = 1 Тогда
			Если DeactivateGhostService() = 0 Тогда
				FUseGhostService = 1;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры



//==============================================================================
//----------   Выгрузка ТЗ в Excel  --------------------------------------------
//==============================================================================
Function WriteVT(VT)
	Var Excel;
	
	Excel = CreateObject("Excel.Application");
	Excel.Visible = 1;

	WB = Excel.Workbooks.Add();
	Sh = WB.ActiveSheet();
	Sh.Visible = 1;
	
	for i=1 To VT.ColumnCount() Do
		Sh.Cells(1, i).Value = VT.GetColumnParameters(i);
	EndDo;
	
	Row = 2;
	VT.SelectLines();
	While VT.GetLine()=1 Do
		If (VT.LineNum%10)=0 Then
			Status("Writing  "+VT.LineNum+"/"+VT.LinesCnt());
		EndIf;
		For i=1 To VT.ColumnCount() Do
			Value = VT.GetValue(Row-1, i);
			If ValueType(Value)>3 Then
				Value = String(Value);
			EndIf;
			If ValueType(Value)=2 Then
				Sh.Cells(Row, i).NumberFormat = "@";
			EndIf;
			Sh.Cells(Row, i).Value = Value;
		EndDo;
		Row = Row + 1;
	EndDo;
	
	Sh.Cells(1,1).AutoFilter();
	Sh.Cells(2,1).Select();
	Excel.ActiveWindow.FreezePanes = 1;
	
	Sh = "";
	Excel = "";

	Return WB;
EndFunction

//_____________________________________________________________________________
Procedure LoadVT()
	Перем _ТЗ_;
	
	_ТЗ_ = СоздатьОбъект("ТаблицаЗначений");
	
	Сп = СоздатьОбъект("СписокЗначений");
	Сп.Установить("СписокСохранения", НастройкиЗагрузкиExcel);
	Сп.Установить("ТЗ", _ТЗ_);
	Сп.Установить("Функция", "Считать");
	Сп.Установить("Редактировать", 1);
	Парам = Сп;

	ОткрытьОбработку("FromExcel", Парам, 1);
	//_ТЗ_ = Сп.Получить("ТЗ");
	//Если ТипЗначенияСтр(_ТЗ_) <> "ТаблицаЗначений" Тогда Возврат; КонецЕсли;
	Если _ТЗ_.КоличествоКолонок() = 0 Тогда Возврат; КонецЕсли;
	
	ТЗ.Загрузить(_ТЗ_);
EndProcedure

//=============================================================================
//=====  Функция записи/чтения ТЗ в файл/из файла  ============================
//=============================================================================
//_____________________________________________________________________________
Процедура ЗаписатьСтрокуВФайл(Файл, Стр, НомерСтроки)
	Перем лСтр;
	
	лСтр = СтрЗаменить(Стр, "\", "\\");
	лСтр = СтрЗаменить(лСтр, РазделительСтрок, "\n");
	
	Если ТипЗначенияСтр(Файл)="Текст" Тогда
		Файл.ДобавитьСтроку(лСтр);
	Иначе
		Файл.ЗаписатьСтроку(лСтр);
	КонецЕсли;
	НомерСтроки = НомерСтроки + 1;
	
	Если (НомерСтроки%100) = 0 Тогда
		Состояние("Запись строки "+НомерСтроки);
	КонецЕсли;
КонецПроцедуры

//_____________________________________________________________________________
Процедура ЗначВФайл(Файл, Значение, Прогресс)
	Перем Тип, стрТип;
	Тип = ТипЗначения(Значение);
	стрТип = ТипЗначенияСтр(Значение);
	Если Тип=1 Тогда
		ЗаписатьСтрокуВФайл(Файл, "Ч,"+Значение, Прогресс);
	ИначеЕсли Тип=2 Тогда
		ЗаписатьСтрокуВФайл(Файл, "С,"+Значение, Прогресс);
	ИначеЕсли Тип=3 Тогда
		ЗаписатьСтрокуВФайл(Файл, "Д,"+Формат(Значение, "ДДДММГГГГ"), Прогресс);
	ИначеЕсли (Тип>=10) И (Тип<=15) Тогда
		ЗаписатьСтрокуВФайл(Файл, "Агр,"+ЗначениеВСтроку(Значение), Прогресс);
	ИначеЕсли (стрТип = "ТаблицаЗначений") ИЛИ (стрТип = "Общие.ТаблицаЗначений") Тогда
		ТЗВФайл(Значение, Файл, Прогресс);
	ИначеЕсли стрТип = "СписокЗначений" Тогда
		ТЗВФайл(Значение, Файл, Прогресс);
	ИначеЕсли стрТип = "DynaValue" Тогда
		ТЗВФайл(Значение, Файл, Прогресс);
	Иначе
		ЗаписатьСтрокуВФайл(Файл, ","+ЗначениеВСтроку(Значение), Прогресс);
	КонецЕсли;
КонецПроцедуры

//_____________________________________________________________________________
Процедура ТЗВФайл(ТЗ, Файл, Прогресс=1)
	Перем Стр;
	Перем ИмяКолонки, Тип, Длина, Точность, Заголовок, Ширина, ФорматКолонки, Положение;
	Перем Значение, НСтр, НКол;
	
	ТипТЗ = ТипЗначенияСтр(ТЗ);
	
	//Заголовок
	Если (ТипТЗ = "ТаблицаЗначений") ИЛИ (ТипТЗ = "Общие.ТаблицаЗначений") Тогда
		Если ТипТЗ = "Общие.ТаблицаЗначений" Тогда
			ИД = "{ОТЗ";
		Иначе
			ИД = "{ТЗ";
		КонецЕсли;
		ЗаписатьСтрокуВФайл(Файл, ИД+","+ТЗ.КоличествоКолонок()+","+ТЗ.КоличествоСтрок(), Прогресс);
		Для н=1 По ТЗ.КоличествоКолонок() Цикл
			ИмяКолонки = ТЗ.ПолучитьПараметрыКолонки(н, Тип, Длина, Точность, Заголовок, Ширина, ФорматКолонки, Положение);
			ЗаписатьСтрокуВФайл(Файл, " "+ИмяКолонки+", "+Тип+","+Длина+","+Точность+","+Ширина+","+Положение+", "+Заголовок+СимволТабуляции+ФорматКолонки, Прогресс);
		КонецЦикла;
	ИначеЕсли ТипТЗ = "СписокЗначений" Тогда
		ЗаписатьСтрокуВФайл(Файл, "{СЗ,"+ТЗ.РазмерСписка(), Прогресс);
	ИначеЕсли ТипТЗ = "DynaValue" Тогда
		ЗаписатьСтрокуВФайл(Файл, "{DV,"+ТЗ.КоличествоСвойств(), Прогресс);
	КонецЕсли;

	//Содержимое
	Если (ТипТЗ = "ТаблицаЗначений") ИЛИ (ТипТЗ = "Общие.ТаблицаЗначений") Тогда
		Для НСтр=1 По ТЗ.КоличествоСтрок() Цикл
			Для НКол=1 По ТЗ.КоличествоКолонок() Цикл
				Значение = ТЗ.ПолучитьЗначение(НСтр, НКол);
				ЗначВФайл(Файл, Значение, Прогресс);
			КонецЦикла;
		КонецЦикла;
		
	ИначеЕсли ТипТЗ = "СписокЗначений" Тогда
		Для НСтр=1 По ТЗ.РазмерСписка() Цикл
			Значение = ТЗ.ПолучитьЗначение(НСтр, Стр);
			ЗначВФайл(Файл, Стр, Прогресс);
			ЗначВФайл(Файл, Значение, Прогресс);
		КонецЦикла;
		
	ИначеЕсли ТипТЗ = "DynaValue" Тогда
		ТЗ.ВыбратьСвойства();
		Пока ТЗ.ПолучитьСвойство(Значение, Стр) = 1 Цикл
			ЗначВФайл(Файл, Стр, Прогресс);
			ЗначВФайл(Файл, Значение, Прогресс);
		КонецЦикла;
	КонецЕсли;
	
	ЗаписатьСтрокуВФайл(Файл, "}", Прогресс);
КонецПроцедуры

//_____________________________________________________________________________
// Получить следующий токен (лексический элемент) из строки
// Стр - разбираемая строка
// Поз - текущая позиция в строке
// Токен - возвращаемый токен
// Возвращаемое значение: 1 - токен найден, 0 - не найден
// 
// При лексическом разборе используются две глобальные переменные:
// глРазделители - строка символов - разделителей (по умолчанию ",; "+СимволТабуляции)
// глСпецСимволы - символы, имеющие специальное лексическое значение ("+-/*=")
//_____________________________________________________________________________
Функция ПолучитьТокен(Стр, Поз, Токен, глРазделители = ",") Экспорт
	Перем Длина, Начало;
	Перем Сим;
	
	Длина = СтрДлина(Стр);
	
	//Пропускаем резделители
	Пока Поз<=Длина Цикл
		Сим = Сред(Стр, Поз, 1);
		Если Найти(глРазделители, Сим)=0 Тогда
			Прервать;
		КонецЕсли;
		Поз = Поз + 1;
	КонецЦикла;

	Если Поз>Длина Тогда
		Токен = "";
		Возврат 0;
	КонецЕсли;
	
	Начало = Поз;
	//Выделяем токен
	Пока Поз<=Длина Цикл
		Сим = Сред(Стр, Поз, 1);
		Если Найти(глРазделители, Сим)>0 Тогда
			Прервать;
		КонецЕсли;
		Поз = Поз + 1;
	КонецЦикла;
	
	Токен = Сред(Стр, Начало, Поз-Начало);
	Возврат 1;
КонецФункции

//_____________________________________________________________________________
Функция ПолучитьСтроку(Файл, НомерСтроки)
	Перем Рез, Стр, РезСтр, Поз;
	
	Если ТипЗначенияСтр(Файл)="Текст" Тогда
		Стр = Файл.ПолучитьСтроку(НомерСтроки);
	Иначе
		Рез = Файл.ПрочитатьСтроку(Стр);
		Если Рез=0 Тогда
			Стр = "";
		КонецЕсли;
	КонецЕсли;
	НомерСтроки = НомерСтроки + 1;
	
	Поз = Найти(Стр, "\");
	РезСтр = "";
	Пока Поз > 0 Цикл
		РезСтр = РезСтр + Лев(Стр, Поз - 1);
		Если Сред(Стр, Поз+1, 1) = "\" Тогда      // два слэша трансформируем в один слэш
			РезСтр = РезСтр + "\";
			Стр = Сред(Стр, Поз+2);
		ИначеЕсли Сред(Стр, Поз+1, 1) = "n" Тогда // \n трансформируем в РазделительСтрок
			РезСтр = РезСтр + РазделительСтрок;
			Стр = Сред(Стр, Поз+2);
		Иначе                                     // просто слэш так и оставляем - это старый формат файла
			РезСтр = РезСтр + "\";
			Стр = Сред(Стр, Поз);
		КонецЕсли;
		Поз = Найти(Стр, "\");
	КонецЦикла;
	РезСтр = РезСтр + Стр;
	
	Возврат РезСтр;
КонецФункции

//_____________________________________________________________________________
Функция ЗначИзФайла(Файл, НомерСтроки, _Стр_=0)
	Перем Стр, Поз, Тип, Значение;
	
	Если ТипЗначения(_Стр_)=2 Тогда
		Стр = _Стр_; НомерСтроки = НомерСтроки + 1;
	Иначе
		Стр = ПолучитьСтроку(Файл, НомерСтроки);
	КонецЕсли;
	Если (НомерСтроки%100)=0 Тогда
		Состояние("Считываю строку "+НомерСтроки);
	КонецЕсли;
	
	Поз = Найти(Стр, ",");
	Тип = Лев(Стр, Поз-1);
	Значение = Сред(Стр, Поз+1);
	
	Если Тип="Ч" Тогда
		Значение = Число(Значение);
	ИначеЕсли Тип="Д" Тогда
		Значение = Дата(Значение);
	//ИначеЕсли Тип="С" Тогда
	//	Значение = Строка(Значение);
	ИначеЕсли Тип="Агр" Тогда
		Значение = ЗначениеИзСтроки(Значение);
	ИначеЕсли Тип="{ТЗ" Тогда
		НомерСтроки = НомерСтроки - 1;
		Значение = ТЗИзФайла(Файл, НомерСтроки, Стр);
	ИначеЕсли Тип="{ОТЗ" Тогда
		НомерСтроки = НомерСтроки - 1;
		Значение = ТЗИзФайла(Файл, НомерСтроки, Стр);
	ИначеЕсли Тип="{СЗ" Тогда
		НомерСтроки = НомерСтроки - 1;
		Значение = ТЗИзФайла(Файл, НомерСтроки, Стр);
	ИначеЕсли Тип="{DV" Тогда
		НомерСтроки = НомерСтроки - 1;
		Значение = ТЗИзФайла(Файл, НомерСтроки, Стр);
	ИначеЕсли Тип="" Тогда
		Значение = ЗначениеИзСтроки(Значение);
	КонецЕсли;
	
	Возврат Значение;
КонецФункции
//_____________________________________________________________________________
Функция ТЗИзФайла(Файл, НомерСтроки=1, _Стр_=0)
	Перем Стр, Поз, Токен;
	Перем ТЗ, ЧислоКолонок, ЧислоСтрок;
	Перем ИмяКолонки, Тип, Длина, Точность, Заголовок, Ширина, ФорматКолонки, Положение;
	Перем НСтр, НКол;
	Перем Значение, СтрЗнач;
	
	//Считываем шапку
	Если ТипЗначения(_Стр_)=2 Тогда
		Стр = _Стр_; НомерСтроки = НомерСтроки + 1;
	Иначе
		Стр = ПолучитьСтроку(Файл, НомерСтроки);
	КонецЕсли;

	Поз = 1;
	ПолучитьТокен(Стр, Поз, Токен);
	Если (Токен="{ТЗ") ИЛИ (Токен="{ОТЗ") Тогда
		Если (Токен="{ОТЗ") Тогда
			ТЗ = СоздатьОбъект("Общие.ТаблицаЗначений");
		Иначе
			ТЗ = СоздатьОбъект("ТаблицаЗначений");
		КонецЕсли;
		ПолучитьТокен(Стр, Поз, Токен); ЧислоКолонок = Число(Токен);
		ПолучитьТокен(Стр, Поз, Токен); ЧислоСтрок = Число(Токен);
		//Сообщить("ТЗ: колонок - "+ЧислоКолонок+", строк - "+ЧислоСтрок);
		
		//Создаем колонки ТЗ
		Для НКол=1 По ЧислоКолонок Цикл
			Стр = ПолучитьСтроку(Файл, НомерСтроки);
			Поз = 1;
			ПолучитьТокен(Стр, Поз, Токен); Имя = СокрЛП(Токен);
			ПолучитьТокен(Стр, Поз, Токен); Тип = СокрЛП(Токен);
			ПолучитьТокен(Стр, Поз, Токен); Длина = Число(Токен);
			ПолучитьТокен(Стр, Поз, Токен); Точность = Число(Токен);
			
			ПолучитьТокен(Стр, Поз, Токен); Ширина = Число(Токен);
			ПолучитьТокен(Стр, Поз, Токен); Положение = Число(Токен);
            //Всё остальное может содержать ",", поэтому разделитель - табуляция.
			Поз = Поз + 1; //Пропустим запятую
			ПолучитьТокен(Стр, Поз, Токен, СимволТабуляции); Заголовок = СокрЛП(Токен);
			ПолучитьТокен(Стр, Поз, Токен, СимволТабуляции); ФорматКолонки = Токен;
			
			ТЗ.НоваяКолонка(Имя, Тип, Длина, Точность, Заголовок, Ширина, ФорматКолонки, Положение);
		КонецЦикла;
	ИначеЕсли Токен="{СЗ" Тогда
		ТЗ = СоздатьОбъект("СписокЗначений");
		ПолучитьТокен(Стр, Поз, Токен); ЧислоСтрок = Число(Токен);
	ИначеЕсли Токен="{DV" Тогда
		ТЗ = СоздатьОбъект("DynaValue");
		ПолучитьТокен(Стр, Поз, Токен); ЧислоСтрок = Число(Токен);
	Иначе
		Сообщить("Неверный формат файла: неожиданный токен '"+Токен+"' : стр "+НомерСтроки, "!");
		Возврат ТЗ;
	КонецЕсли;
	
	стрТип = ТипЗначенияСтр(ТЗ);
	Если (стрТип="ТаблицаЗначений") ИЛИ (стрТип="Общие.ТаблицаЗначений") Тогда
		//Считываем строки ТЗ
		Для НСтр=1 По ЧислоСтрок Цикл
			ТЗ.НоваяСтрока();
			Для НКол=1 По ЧислоКолонок Цикл
				ТЗ.УстановитьЗначение(НСтр, НКол, ЗначИзФайла(Файл, НомерСтроки));
			КонецЦикла;
		КонецЦикла;
	ИначеЕсли стрТип="СписокЗначений" Тогда
		Для НСтр=1 По ЧислоСтрок Цикл
			Стр = ЗначИзФайла(Файл, НомерСтроки);
			Если ТипЗначения(Стр)<>2 Тогда
				Сообщить("Неверный формат файла! Ожидалось строковое значение для списка, получили '"+Стр+"' : стр "+НомерСтроки, "!");
				Возврат ТЗ;
			КонецЕсли;
			Значение = ЗначИзФайла(Файл, НомерСтроки);
			ТЗ.ДобавитьЗначение(Значение, Стр);
		КонецЦикла;
	ИначеЕсли стрТип="DynaValue" Тогда
		Для НСтр=1 По ЧислоСтрок Цикл
			Стр = ЗначИзФайла(Файл, НомерСтроки);
			Если ТипЗначения(Стр)<>2 Тогда
				Сообщить("Неверный формат файла! Ожидалось строковое значение для DynaValue, получили '"+Стр+"' : стр "+НомерСтроки, "!");
				Возврат ТЗ;
			КонецЕсли;
			Значение = ЗначИзФайла(Файл, НомерСтроки);
			ТЗ.ДобавитьСвойство(Стр, Значение);
		КонецЦикла;
	КонецЕсли;
	
	Стр = ПолучитьСтроку(Файл, НомерСтроки);
	Если Стр<>"}" Тогда
		Сообщить("Неверный формат файла: отсутствует '}': стр "+НомерСтроки, "!");
	КонецЕсли;

	Возврат ТЗ;
КонецФункции

//_____________________________________________________________________________
Функция ВыборИмениФайла(ИмяФайла)
	Перем Каталог;
	Если ФС.ВыбратьФайл(0, ИмяФайла, Каталог, "Выберите файл с ТЗ", "Файлы ТЗ (*.ТЗ) |*.ТЗ|Файлы импорта (*.imp) |*.imp|Текстовые (*.txt) |*.txt|Все файлы (*.*) |*.*")=1 Тогда
		ИмяФайла = Каталог + ИмяФайла;
		Возврат 1;
	КонецЕсли;
	Возврат 0;
КонецФункции

//_____________________________________________________________________________
Функция CreateV7TextFile(ИмяФайла, Режим)
	Если ЗагрузитьВнешнююКомпоненту("v7plus.dll")=0 Тогда
		//Сообщить("Не удалось обнаружить компоненту v7plus.dll!"); 
		Возврат 0;
	КонецЕсли;

	Попытка
		Файл = СоздатьОбъект("AddIn.V7TextFile");
	Исключение 
		Сообщить("Не удалось создать объект Addin.V7TextFile!");
		Возврат 0;
	КонецПопытки; 

	Если ПустоеЗначение(ИмяФайла)=1 Тогда 
		Если ВыборИмениФайла(ИмяФайла)=0 Тогда
			Возврат 0;
		КонецЕсли;
	КонецЕсли;

	Файл.ОткрытьФайл(ИмяФайла, Режим);
	Возврат Файл;
КонецФункции
//_____________________________________________________________________________
Процедура ЗаписатьТЗВФайл(ТЗ, ИмяФайла, ФорматФайла)
	Перем Файл;
	
	Если ПустоеЗначение(ИмяФайла)=1 Тогда 
		Если ВыборИмениФайла(ИмяФайла)=0 Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;

	Если ФорматФайла=1 Тогда
		ЗначениеВФайл(ИмяФайла, ТЗ, 1);
		Возврат;
	ИначеЕсли ФорматФайла=2 Тогда
		ЗначениеВФайл(ИмяФайла, ТЗ, 2);
		Возврат;
	ИначеЕсли ФорматФайла=3 Тогда
		Файл = CreateV7TextFile(ИмяФайла, 1);
		Если ПустоеЗначение(Файл)=1 Тогда
			Файл = СоздатьОбъект("Текст");
		КонецЕсли;
		
		ТЗВФайл(ТЗ, Файл);
		
		Если ТипЗначенияСтр(Файл)="Текст" Тогда
			Файл.Записать(ИмяФайла);
		Иначе
			Файл.ЗакрытьФайл();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

//_____________________________________________________________________________
Функция СчитатьТЗИзФайла(ИмяФайла, ФорматФайла)
	Перем ТЗ, Файл;
	
	Если ПустоеЗначение(ИмяФайла)=1 Тогда 
		Если ВыборИмениФайла(ИмяФайла)=0 Тогда
			Возврат ТЗ;
		КонецЕсли;
	КонецЕсли;

	Если ФорматФайла=1 Тогда
		ЗначениеИзФайла(ИмяФайла, ТЗ, 1);
	ИначеЕсли ФорматФайла=2 Тогда
		ЗначениеИзФайла(ИмяФайла, ТЗ, 2);
	ИначеЕсли ФорматФайла=3 Тогда
		ТЗ = СоздатьОбъект("ТаблицаЗначений");
		Файл = CreateV7TextFile(ИмяФайла, 0);
		Если ПустоеЗначение(Файл)=1 Тогда
			Файл = СоздатьОбъект("Текст");
			Файл.Открыть(ИмяФайла);
		КонецЕсли;
		
		ТЗ = ТЗИзФайла(Файл);
		Если ТипЗначенияСтр(Файл)="Текст" Тогда
			Файл = "";
		Иначе
			Файл.ЗакрытьФайл();
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТЗ;
КонецФункции

//_____________________________________________________________________________
Процедура СчитатьИзФайла()
	Перем ИмяФайла, _ТЗ_, ТЗ_ф;
	
	Если ВыборИмениФайла(ИмяФайла)=0 Тогда
		Возврат;
	КонецЕсли;

	Попытка
		ЗначениеИзФайла(ИмяФайла, _ТЗ_);
		Если ПустоеЗначение(_ТЗ_)=0 Тогда
			ФиксСтрок = 0;
			ФиксКолонок = 0;
			ТЗ.Загрузить(_ТЗ_);
			Возврат;
		КонецЕсли;
	Исключение
	КонецПопытки;

	Попытка
		_ТЗ_ = СчитатьТЗИзФайла(ИмяФайла, 3);
		ФиксСтрок = 0;
		ФиксКолонок = 0;
		ТЗ.Загрузить(_ТЗ_);
		Возврат;
	Исключение
	КонецПопытки;

	Попытка
		_ТЗ_ = СчитатьТЗИзФайла(ИмяФайла, 1);
		ФиксСтрок = 0;
		ФиксКолонок = 0;
		ТЗ.Загрузить(_ТЗ_);
		Возврат;
	Исключение
	КонецПопытки;

	Попытка
		_ТЗ_ = СчитатьТЗИзФайла(ИмяФайла, 2);
		ФиксСтрок = 0;
		ФиксКолонок = 0;
		ТЗ.Загрузить(_ТЗ_);
		Возврат;
	Исключение
	КонецПопытки;
КонецПроцедуры

//=============================================================================
//======  Интерактивные функции  ==============================================
//=============================================================================
//_____________________________________________________________________________
Процедура АвтоНастройкаШирины(ТЗ)
	Перем Колонки, н, Имя, Зн, Ширина;
	Колонки = СоздатьОбъект("ТаблицаЗначений");
	Колонки.НоваяКолонка("Имя", "Строка");
	Колонки.НоваяКолонка("Ширина", "Число");
	Для нк=1 По ТЗ.КоличествоКолонок() Цикл
		Колонки.НоваяСтрока();
		Колонки.Имя = ТЗ.ПолучитьПараметрыКолонки(нк);
	КонецЦикла;
	
	Для н=1 По ТЗ.КоличествоСтрок() Цикл
		Если (н%100)=0 Тогда Состояние(""+н+"/"+ТЗ.КоличествоСтрок()); КонецЕсли;
		
		Колонки.ВыбратьСтроки();
		Пока Колонки.ПолучитьСтроку()=1 Цикл
			Зн = ТЗ.ПолучитьЗначение(н, Колонки.Имя);
			Зн = СокрП(Зн);
			Ширина = СтрДлина(Зн);
			Если Колонки.Ширина<Ширина Тогда
				Колонки.Ширина = Ширина;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	Колонки.ВыбратьСтроки();
	Пока Колонки.ПолучитьСтроку()=1 Цикл
		ТЗ.УстановитьПараметрыКолонки(Колонки.Имя,,,,, Колонки.Ширина);
	КонецЦикла;
КонецПроцедуры
//_____________________________________________________________________________
Процедура Сортировка(Направление)
	Перем Путь;
	Если Направление>0  Тогда
		ТЗ.Сортировать("+"+НомерТекущейКолонки(), 1);
	ИначеЕсли Направление<0  Тогда
		ТЗ.Сортировать("-"+НомерТекущейКолонки(), 1);
	Иначе
		ОткрытьОбработку("СортировкаТЗ", ТЗ, 1);
	КонецЕсли;
	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура ПоказатьСтруктуруТЗ()
	Перем Структ;
	Перем Идентификатор, Тип, Длина, Точность, Заголовок, Ширина;
	
	Структ = СоздатьОбъект("ТаблицаЗначений");
	Структ.НоваяКолонка("Идентификатор", "Строка");
	Структ.НоваяКолонка("Тип", "Строка");
	Структ.НоваяКолонка("Длина", "Число", 3, 0);
	Структ.НоваяКолонка("Точность", "Число", 3, 0);
	Структ.НоваяКолонка("Заголовок", "Строка");
	Структ.НоваяКолонка("Ширина", "Число", 4, 0);
	
	Для н=1 По ТЗ.КоличествоКолонок() Цикл
		Структ.НоваяСтрока();
		Идентификатор = ТЗ.ПолучитьПараметрыКолонки(н, Тип, Длина, Точность, Заголовок, Ширина);
		Структ.Идентификатор = Идентификатор;
		Структ.Тип = Тип;
		Структ.Длина = Длина;
		Структ.Точность = Точность;
		Структ.Заголовок = Заголовок;
		Структ.Ширина = Ширина;
	КонецЦикла;
	
	РедакторТЗ(Структ);
КонецПроцедуры

//_____________________________________________________________________________
Процедура Фильтр()
	Перем Выбор;
	
	Меню = СоздатьОбъект("СписокЗначений");
	Меню.ДобавитьЗначение("УдалитьДо", "Удалить все строки до текущей");
	Меню.ДобавитьЗначение("УдалитьПосле", "Удалить все строки после текущей");
	Меню.ДобавитьЗначение("Фильтр", "Сложный фильтр");
	Ответ = Меню.ВыбратьЗначение(Выбор,,,, 1);
	Если Ответ <> 1 Тогда
		Возврат;
	КонецЕсли;
	
	Если Выбор = "УдалитьДо" Тогда
		н = ТЗ.ТекущаяСтрока() - 1;
		Если н > 0 Тогда
			Пока н > 0 Цикл
				ТЗ.УдалитьСтроку(н);
				н = н - 1;
			КонецЦикла;
			ТЗ.ТекущаяСтрока(1);
		КонецЕсли;
		
	ИначеЕсли Выбор = "УдалитьПосле" Тогда
		н = ТЗ.ТекущаяСтрока();
		н1 = ТЗ.КоличествоСтрок();
		Пока н1 > н Цикл
			ТЗ.УдалитьСтроку(н);
			н1 = н1 - 1;
		КонецЦикла;
		ТЗ.ТекущаяСтрока(н);
		
	Иначе
		Сп = СоздатьОбъект("СписокЗначений");
		Сп.Установить("ТЗ", ТЗ);
		Сп.Установить("ТипОбъекта", "ТаблицаЗначений");
		Сп.Установить("Функция", "Редактировать");
		Сп.Установить("Фильтр", ТЗ_Фильтр);
		Сп.Установить("Реквизиты", ТЗ_РеквизитыФильтра);
		ОткрытьОбработку("ПараметрическийФильтр", Сп, 0);
	КонецЕсли;
КонецПроцедуры

//_____________________________________________________________________________
Процедура ДляКаждойСтроки()
	Перем Значение, Колонка, НомерКолонки;
	
	Колонка = ТЗ.ТекущаяКолонка(, НомерКолонки);
	Отв = ВвестиСтроку(ПрограммныйКод, "Выражение для формировния колонки '"+Колонка+"'. Для обращения к текущей таблице используйте ТЗ.", , 1);
	Если Отв <> 1 Тогда
		Возврат;
	КонецЕсли;
	
	ТЗ.ВыбратьСтроки();
	Пока ТЗ.ПолучитьСтроку() = 1 Цикл
		Состояние(""+ТЗ.НомерСтроки);
		Шаблон("[Присвоить(Значение, "+ПрограммныйКод+")]");
		ТЗ.УстановитьЗначение(ТЗ.НомерСтроки, НомерКолонки, Значение);
	КонецЦикла;
КонецПроцедуры

//_____________________________________________________________________________
Процедура Печать()
	Сп = СоздатьОбъект("СписокЗначений");
	//НастройкиПечати.Выгрузить(Сп);
	Сп.Установить("СписокСохранения", НастройкиПечати);
	Сп.Установить("ТЗ", ТЗ);
	ОткрытьОбработку("ПечатьТЗ", Сп, 0, 1);
КонецПроцедуры


//_____________________________________________________________________________
Процедура ВыборФункции()
	Перем Колонка, Функ, н;
	Перем Сп;
	
	Колонка = ТЗ.ТекущаяКолонка();
	//Функ = СпФункции.ПолучитьЗначение(н);
	Если СпФункции.ВыбратьЗначение(Функ, "",,, 1)=0 Тогда
		Возврат;
	КонецЕсли;
	
	
	Если Функ="СкрытьКолонку"  Тогда
		ТЗ.ВидимостьКолонки(Колонка, 0);
	ИначеЕсли Функ="ПоказатьКолонки"  Тогда
		Для н=1 По ТЗ.КоличествоКолонок() Цикл
			ТЗ.ВидимостьКолонки(н, 1);
		КонецЦикла;
	ИначеЕсли Функ="УдалитьКолонку"  Тогда
		УдалитьКолонку();
	ИначеЕсли Функ="ПараметрыКолонки"  Тогда
		РедактироватьКолонку();
		
	ИначеЕсли Функ="АвтоШирина"  Тогда
		АвтоНастройкаШирины(ТЗ);
	ИначеЕсли Функ="ToExcel"  Тогда
		WriteVT(ТЗ);
	ИначеЕсли Функ="FromExcel"  Тогда
		LoadVT();
	ИначеЕсли Функ="СчитатьИзФайла"  Тогда
		СчитатьИзФайла();
	ИначеЕсли Функ="ЗаписатьВФайл"  Тогда
		ЗаписатьТЗВФайл(ТЗ,, 3);
	ИначеЕсли Функ="ЗаписатьВФайлСтд"  Тогда
		ЗаписатьТЗВФайл(ТЗ,, 1);
	ИначеЕсли Функ="ПодобратьСумму" Тогда
		РасположениеФайла(Путь,);
		Сп = СоздатьОбъект("СписокЗначений");
		Сп.Установить("ТЗ", ТЗ);
		ОткрытьОбработку("ПодборСуммы", Сп, 0);
		Возврат;
	ИначеЕсли Функ="ДляКаждойСтроки" Тогда
		ДляКаждойСтроки();
	ИначеЕсли Функ="Фильтр" Тогда
		Фильтр();
		Возврат;
	ИначеЕсли Функ="Свернуть"  Тогда
		Сп = СоздатьОбъект("СписокЗначений");
		Сп.Установить("Функция", "Свернуть");
		Сп.Установить("ТЗ", ТЗ);
		ОткрытьОбработку("СортировкаТЗ", Сп, 1);
		//Возврат;
	ИначеЕсли Функ="Структура"  Тогда
		ПоказатьСтруктуруТЗ();
		Возврат;
	ИначеЕсли Функ="Печать"  Тогда
		Печать();
		Возврат;
	ИначеЕсли Функ="УникальныеЗначения"  Тогда
		ТЗ_Уникальные = СоздатьОбъект("ТаблицаЗначений");
		ТЗ.Выгрузить(ТЗ_Уникальные,,, НомерТекущейКолонки());
		ТЗ_Уникальные.Свернуть("1", "");
		ТЗ_Уникальные.Сортировать("1");
		РедакторТЗ(ТЗ_Уникальные, "Уникальные значения в колонке """+ТЗ.ТекущаяКолонка()+"""", 1);
	КонецЕсли;
	
	Активизировать("ТЗ");
КонецПроцедуры

//_____________________________________________________________________________
Процедура ДоступностьКнопокРедактированияКолонки(Доступность)
	Форма.КнНоваяКолонка.Доступность(Доступность);
	Форма.КнКопироватьКолонку.Доступность(Доступность);
	Форма.КнРедактироватьКолонку.Доступность(Доступность);
	Форма.КнУдалитьКолонку.Доступность(Доступность);
	Форма.КнВлево.Доступность(Доступность);
	Форма.КнВправо.Доступность(Доступность);
КонецПроцедуры

//_____________________________________________________________________________
Процедура ДоступностьКнопокРедактирования(Доступность)
	Форма.КнНовая.Доступность(Доступность);
	Форма.КнКопировать.Доступность(Доступность);
	Форма.КнРедактировать.Доступность(Доступность);
	Форма.КнУдалить.Доступность(Доступность);
	Форма.КнВверх.Доступность(Доступность);
	Форма.КнВниз.Доступность(Доступность);

	ДоступностьКнопокРедактированияКолонки(Доступность);
	
	Форма.КнСортировать1.Доступность(Доступность);
	Форма.КнСортировать2.Доступность(Доступность);
	Форма.КнСортировать3.Доступность(Доступность);
	//Форма.КнПоиск1.Доступность(Доступность);
	//Форма.КнПоиск2.Доступность(Доступность);
	//Форма.КнПоиск3.Доступность(Доступность);
	//Форма.КнПоиск4.Доступность(Доступность);
КонецПроцедуры

//_____________________________________________________________________________
Функция ВыполнитьФункцию()
	Перем Сп, Функ, ТЗ;
	
	Сп = Форма.Параметр;
	Если ТипЗначенияСтр(Сп)<>"СписокЗначений" Тогда Возврат 0; КонецЕсли;
	Функ = Сп.Получить("Функция");
	Если ПустоеЗначение(Функ)=1 Тогда Возврат 0; КонецЕсли;
	Если ТипЗначения(Функ)<>2 Тогда Возврат 0; КонецЕсли;

	Если Функ="ЗаписатьВФайл" Тогда
		ТЗ = Сп.Получить("ТЗ");
		Если (ТипЗначенияСтр(ТЗ)<>"ТаблицаЗначений") И (ТипЗначенияСтр(ТЗ)<>"СписокЗначений") Тогда Возврат 0; КонецЕсли;
		ИмяФайла = Сп.Получить("ИмяФайла");
		ФорматФайла = Сп.Получить("ФорматФайла");
		Если ПустоеЗначение(ФорматФайла)=1 Тогда
			ФорматФайла = 3;
		КонецЕсли;
		ЗаписатьТЗВФайл(ТЗ, ИмяФайла, ФорматФайла);
		Форма.Параметр.Установить("ИмяФайла", ИмяФайла);
		Возврат 1;
	ИначеЕсли Функ="СчитатьИзФайла" Тогда
		ИмяФайла = Сп.Получить("ИмяФайла");
		ФорматФайла = Сп.Получить("ФорматФайла");
		Если ПустоеЗначение(ФорматФайла)=1 Тогда
			ФорматФайла = 3;
		КонецЕсли;
		ТЗ = СчитатьТЗИзФайла(ИмяФайла, ФорматФайла);
		Сп.Установить("ТЗ", ТЗ);
		Форма.Параметр = ТЗ;
		Возврат 1;
	ИначеЕсли Функ="ToExcel" Тогда
		ИмяФайла = Сп.Получить("ИмяФайла");
		Book = WriteVT(ТЗ);
		Если ПустаяСтрока(ИмяФайла)=0 Тогда
			Book.SaveAs(ИмяФайла);
		КонецЕсли;
		Book = "";
	КонецЕсли;
	
	Возврат 0;
КонецФункции

//_____________________________________________________________________________
Функция Присвоить(ЛевЗнач, ПравЗнач="")
	ЛевЗнач = ПравЗнач;
	Возврат ЛевЗнач;
КонецФункции

//_____________________________________________________________________________
Функция НайтиДокумент(Документ, ЗначРекв = "")
	Если ТипЗначения(Документ) = 12 Тогда
		Док = СоздатьОбъект("Документ");
		Док.НайтиДокумент(Документ);
	Иначе
		Док = СоздатьОбъект("Документ");
		Док.ВыбратьПоЗначению(,, СокрЛП(Документ), ЗначРекв);
		Док.ПолучитьДокумент();
	КонецЕсли;
	Возврат Док;
КонецФункции
Функция НайтиЭлемент(Элемент)
	Спр = СоздатьОбъект("Справочник."+Элемент.Вид());
	Спр.НайтиЭлемент(Элемент);
	Возврат Спр;
КонецФункции

//_____________________________________________________________________________
//  Параметры, передаваемые через список значений:
//
// - ТЗ - ТЗ для редактирования или выбора
//
// - Заголовок - заголовок окна
//
// - АвтоНастройкаШириныКолонок - если 1, то при открытии ширина колонок будет настроена автоматически
//
// - ТолькоПросмотр - если 1, то форма открывается только для просмотра. 
//   Все кнопки редактирования становятся неактивными
//
// - ДляВыбора - если 1, то форма работает как форма выбора
//
// - ОбработкаВыбора - если задан этот параметр, при выборе значения (doubleclick на ячейку ТЗ)
//   будет запущена альтернативная обработка выбора. Если ОбработкаВыбора - число, то выполнится функция
//   Форма.ВыполнитьВыбор() - это позволяет использовать редактор ТЗ как форму для подбора.
//   Если ОбработкаВыбора - строка или агр. объект - то будет открыта форма объекта ОбработкаВыбора. Т.е.:
//   ОткрытьФормуМодально(ОбработкаВыбора, спПараметры);
//   или
//   ОткрытьФормуМодально(ОбработкаВыбора, спПараметры, ОбработкаВыбора_Отчет); если обработчик - внешний отчет
//   Подробнее см. функцию АльтернативнаяОбработкаВыбора.
//   В самой форме - обработчике альтернативного выбора нужно анализировать Форма.Параметр 
//   в процедуре ПриОткрытии() или ПриПовторномОткрытии(), и выполнять необходимые действия.
//   По умолчанию после альтернативной обработки выполнится стандартная обработка. Если это
//   нежелательно, то в обработчике нужно сказать Форма.Параметр.Установить("СтандартнаяОбработка", 0);
//   Чтобы форма-обработчик не оставалась активной, нужно сказать 
//   Форма.Параметр.Получить("Контекст").Активизировать("ТЗ"); - т.е. активизировать ТЗ в форме 
//   редактора ТЗ.
//
// - ОбработкаВыбора_Отчет - если ОбработкаВыбора = "Отчет", то в параметре ОбработкаВыбора_Отчет 
//   должно передаваться имя внешнего отчета. В противном случае возникнет ошибка.
//
// - ОбработкаВыбора_Параметры - любое значение. Это значение будет передано в альтернативный обработчик
//   в исходном виде. Обратиться к нему можно как Форма.Парамет.Получить("Параметры").
//
// - ВозвращатьСписок - имеет смысл только для режима выбора. Если 1, то параметры 
//   выбранной позиции сохраняются в список значений {"ВыбраннаяСтрока", "ВыбраннаяКолонка", "ВыбранноеЗначение"},
//   и в список параметров (Форма.Параметр) запишется "ВыбраннаяПозиция"
//   Если параметр не задан, то в Форма.Параметр добавляются "ВыбраннаяСтрока", "ВыбраннаяКолонка", "ВыбранноеЗначение"
//
// - НастройкиПечати - СписокЗначений. Если задан, то настройки печати будут сохраняться в этот список
//_____________________________________________________________________________
Процедура ПриОткрытии()
	Перем АвтоШирина;
	
	Если ВыполнитьФункцию()=1 Тогда 
		СтатусВозврата(0);
		Возврат;
	КонецЕсли;
	
	ТЗ_Фильтр = СоздатьОбъект("ТаблицаЗначений");
	ТЗ_РеквизитыФильтра = СоздатьОбъект("ТаблицаЗначений");
	ФиксСтрок = 0;
	ФиксКолонок = 0;
	ТолькоПросмотр = 0;
	ФормаДляВыбора = 0; ВозвращатьСписок = 0;
	
	Попытка
		ИсходнаяТЗ = Форма.Параметр.Получить("ТЗ");
	Исключение
	КонецПопытки;
	
	Если ТипЗначенияСтр(Форма.Параметр) = "СписокЗначений" Тогда
		ИсходнаяТЗ = Форма.Параметр.Получить("ТЗ");
		
		Если (ТипЗначенияСтр(ИсходнаяТЗ) = "ТаблицаЗначений") ИЛИ ((ТипЗначенияСтр(ИсходнаяТЗ) = "ИндексированнаяТаблица")) Или (ТипЗначенияСтр(ИсходнаяТЗ) = "СписокЗначений") Тогда
			//получили список с параметрами
			Заголовок = Строка(Форма.Параметр.Получить("Заголовок"));
			Форма.Заголовок(Заголовок, 0);
			АвтоШирина       = Число(Форма.Параметр.Получить("АвтоШирина"));
			ТолькоПросмотр   = Число(Форма.Параметр.Получить("ТолькоПросмотр"));
			ФормаДляВыбора   = Число(Форма.Параметр.Получить("ДляВыбора"));
		
			ОбработкаВыбора  = Форма.Параметр.Получить("ОбработкаВыбора");
			ОбработкаВыбора_Отчет = Форма.Параметр.Получить("ОбработкаВыбора_Отчет");
			ОбработкаВыбора_Параметры = Форма.Параметр.Получить("ОбработкаВыбора_Параметры");
		
			ВозвращатьСписок = Число(Форма.Параметр.Получить("ВозвращатьСписок"));
			НастройкиПечати  = Форма.Параметр.Получить("НастройкиПечати");
		
			ДоступностьКнопокРедактирования(?(ТолькоПросмотр = 1, 0, 1));
		Иначе //передали просто список для редактирования
			ИсходнаяТЗ = Форма.Параметр;
		КонецЕсли;
		
		Если ТипЗначенияСтр(ИсходнаяТЗ) = "СписокЗначений" Тогда
			ДоступностьКнопокРедактированияКолонки(0);
		КонецЕсли;
	Иначе
		ИсходнаяТЗ = Форма.Параметр;
	КонецЕсли;

	Если ТипЗначенияСтр(НастройкиПечати) <> "СписокЗначений" Тогда
		НастройкиПечати = СоздатьОбъект("СписокЗначений");
	КонецЕсли;

	ЗагрузитьТЗ();
	Если АвтоШирина = 1 Тогда
		АвтоНастройкаШирины(ТЗ);
	КонецЕсли;
	
	РасположениеФайла(Путь,);

	СпФункции = СоздатьОбъект("СписокЗначений");
	СпФункции.ДобавитьЗначение("АвтоШирина", "Автонастройка ширины колонок");
	Если ТолькоПросмотр = 0 Тогда
		СпФункции.ДобавитьЗначение("СкрытьКолонку", "Скрыть колонку");
		СпФункции.ДобавитьЗначение("ПоказатьКолонки", "Показать все колонки");
		СпФункции.ДобавитьЗначение("УдалитьКолонку", "Удалить колонку");
		СпФункции.ДобавитьЗначение("ПараметрыКолонки", "Параметры колонки");
	КонецЕсли;
	СпФункции.ДобавитьЗначение("ToExcel", "Выгрузить в Excel");
	Если ТолькоПросмотр = 0 Тогда
		СпФункции.ДобавитьЗначение("FromExcel", "Загрузить из Excel");
	КонецЕсли;
	СпФункции.ДобавитьЗначение("ЗаписатьВФайл", "Записать в файл");
	СпФункции.ДобавитьЗначение("ЗаписатьВФайлСтд", "Записать в файл стандартный формат");
	Если ТолькоПросмотр = 0 Тогда
		СпФункции.ДобавитьЗначение("СчитатьИзФайла", "Считать из файла");
	КонецЕсли;
	СпФункции.ДобавитьЗначение("ПодобратьСумму", "Подобрать сумму");
	СпФункции.ДобавитьЗначение("УникальныеЗначения", "Показать уникальные значения");
	Если ФС.СуществуетФайл(Путь+"\ПараметрическийФильтр.ert")=1 Тогда
		СпФункции.ДобавитьЗначение("Фильтр", "Фильтр");
	ИначеЕсли ФС.СуществуетФайл(КаталогИБ()+"ExtForms\ПараметрическийФильтр.ert")=1 Тогда
		СпФункции.ДобавитьЗначение("Фильтр", "Фильтр");
	КонецЕсли;
	Если ТолькоПросмотр = 0 Тогда
		СпФункции.ДобавитьЗначение("ДляКаждойСтроки", "Заполнить текущую колонку");
		СпФункции.ДобавитьЗначение("Свернуть", "Свернуть");
	КонецЕсли;
	СпФункции.ДобавитьЗначение("Печать", "Печать");
	Если ТолькоПросмотр = 0 Тогда
		СпФункции.ДобавитьЗначение("Структура", "Показать структуру ТЗ");
	КонецЕсли;

	Активизировать("ТЗ");
	
	GM_GhostVariableName = СокрЛП(ВосстановитьЗначение("GM_GhostVariableName"));
	FUseGhostService = Число(ВосстановитьЗначение("FUseGhostService"));
	Если FUseGhostService = 1 Тогда
		FUseGhostService = ActivateGhostService(1);
	КонецЕсли;
КонецПроцедуры

Процедура ПриПовторномОткрытии()
	Если ВыполнитьФункцию()=1 Тогда Возврат; КонецЕсли;
	СтатусВозврата(0);
КонецПроцедуры

//_____________________________________________________________________________
Процедура ПриЗакрытии()
	СохранитьЗначение("GM_GhostVariableName", GM_GhostVariableName);
	СохранитьЗначение("FUseGhostService", FUseGhostService);

    DeactivateGhostService();
	
	ВыгрузитьТЗ();
КонецПроцедуры

//_____________________________________________________________________________
Функция ВыбраннуюПозициюВСписок(Сп)
	Перем Стр, Кол, Значение;
	
	Стр = ТЗ.ТекущаяСтрока();
	Кол = ТЗ.ТекущаяКолонка();
	Если ТипЗначения(Кол) = 2 Тогда Кол = ТЗ.ПолучитьПараметрыКолонки(Кол); КонецЕсли;
	Попытка
		Значение = ТЗ.ПолучитьЗначение(Стр, Кол);
	Исключение
	КонецПопытки;
	Сп.Установить("ВыбраннаяСтрока", Стр);
	Сп.Установить("ВыбраннаяКолонка", Кол);
	Сп.Установить("ВыбранноеЗначение", Значение);
	Возврат Сп;
КонецФункции

//_____________________________________________________________________________
Процедура ОК()
	
	Если ФормаДляВыбора = 1 Тогда
		Если ВозвращатьСписок = 1 Тогда
			Сп = СоздатьОбъект("СписокЗначений");
			ВыбраннуюПозициюВСписок(Сп);
			Форма.Параметр.Установить("ВыбраннаяПозиция", Сп);
			Форма.Параметр = Сп;
		Иначе
			ВыбраннуюПозициюВСписок(Форма.Параметр);
			Форма.Параметр = ТЗ.ТекущаяСтрока();
		КонецЕсли;
	Иначе
		Если ТолькоПросмотр = 0 Тогда
			ВыгрузитьТЗ(1);
		КонецЕсли;
	КонецЕсли;
	Форма.Закрыть();
КонецПроцедуры


//_____________________________________________________________________________
//====== Пример обработки ТЗ, записанной в расшифровку ячейки таблицы =========
Процедура ОбработкаЯчейкиТаблицы(Расшифровка, СтандартнаяОбработка, Таблица) Экспорт
	Перем Сп;

	Если ТипЗначенияСтр(Расшифровка) = "ТаблицаЗначений" Тогда
		Сп = СоздатьОбъект("СписокЗначений");
		Сп.Установить("ТЗ", Расшифровка);
		ОткрытьФормуМодально("Обработка.ПечатьТЗ", Сп);
		//РедакторТЗ(Расшифровка, "Расшифровка ячейки");
		Возврат;
	КонецЕсли;
	СтандартнаяОбработка = 1;
КонецПроцедуры

