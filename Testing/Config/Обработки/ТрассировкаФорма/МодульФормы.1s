Перем Трассировка;            // список значений-трассировка
Перем СписокРаскрытыхЗначений;
 
//*****************************************************************************
// Скопировать()
//
// Параметры
//		нет
//
// Вызывается из формул элементов диалога
//		Скопировать
//
// Возвращаемое значение
//		нет
//
// Описание
//		Копирует результат трассировки в отдельную таблицу    
//

Процедура Скопировать()
	
	ИмяФайла=КаталогПользователя()+"Komm_temp";
	Таблица.Записать(ИмяФайла);
	Таблица1 = СоздатьОбъект("Таблица"); 
	Таблица1.Открыть(ИмяФайла);
	Таблица1.ТолькоПросмотр(1);
	Таблица1.Опции(0,0,0,0,);
	Таблица1.Показать("Комментарий выполняемых действий")
	
КонецПроцедуры //Скопировать

//*****************************************************************************
// Очистить()
//
// Параметры
//		нет
//
// Вызывается из формул элементов диалога
//		Очистить
//
// Возвращаемое значение
//		нет
//
// Описание
//		  	 
//
Процедура Очистить()
	
	Если Таблица.ВысотаТаблицы() > 0 тогда
		Если Вопрос("Таблица будет очищена."
			"Продолжить?","Да+Нет")="Нет" Тогда
			Возврат 
		Иначе
			Таблица.Очистить();
			ЗаголовокОкна = "";         
			Таблица.ВывестиСекцию("Описатель");
			Таблица.Показать()
		КонецЕсли
	КонецЕсли	
	
КонецПроцедуры	// Очистить	

//******************************************************************************
// ВывестиВОкноСообщений()
//
// Параметры:
//  <ИмяПараметра> - <ТипПараметра>, <ОписаниеПараметра>.
//
// Вызывается из формул элементов диалога:
// Вызывается из ячеек табличного документа:
//
// Описание:
//  

Процедура ВывестиВОкноСообщений()
	
	СписокСообщений = Трассировка.ПолучитьЗначение(2); // таблица сообщений трассировки    
	Для Сч=1 По СписокСообщений.КоличествоСтрок() Цикл 
		СписокСообщений.ПолучитьСтрокуПоНомеру(Сч);
		Сообщить(СписокСообщений.ТекстСообщения); // текст сообщения
	КонецЦикла;  
	
КонецПроцедуры // ВывестиВОкноСообщений()

Функция ВывестиТекстСообщенияВТаблицу(стрСимвол, стрСообщение)
	Символ = стрСимвол;
	ЧислоСтрок=СтрКоличествоСтрок(стрСообщение);
	ЧислоСтрок=?(ЧислоСтрок=0, 1, ЧислоСтрок);
	Для ъ=1 По ЧислоСтрок Цикл
		СтрокаСообщения = СтрПолучитьСтроку(стрСообщение, ъ);
		Таблица.ВывестиСекцию("Строка");
		Символ="";
	КонецЦикла;
	Возврат ЧислоСтрок;
КонецФункции

//******************************************************************************
//	ОтобразитьТаблицу()
//
//	Параметры: 
//		Режим - Строка, пустая - если таблица нужно открыть, 
//              "Обновить", если попросили обновить таблицу.
//				
//	Возвращаемое значение:
// 		нет
//
//	Описание:
// 		Отображает таблицу обработки - вызывается при открытии и повторном открытии
//
Процедура ОтобразитьТаблицу(Режим = "")
	
	Если Режим = "Обновить" Тогда
		Таблица.Очистить();
	КонецЕсли;	
	Если Таблица.ВысотаТаблицы() > 0 Тогда  // пропустим пустую строку
		Символ=""; СтрокаСообщения ="";
		Таблица.ВывестиСекцию("Строка");
	КонецЕсли;
	СписокСообщений = Трассировка.ПолучитьЗначение(2); // таблица сообщений трассировки    
	Если СписокСообщений.КоличествоСтрок()>0 тогда
		ЗаголовокОкна = Трассировка.ПолучитьЗначение(3,СтрокаСообщения);         
		Таблица.ВывестиСекцию("Описатель"); 
		Таблица.Область(Таблица.ВысотаТаблицы(),1,Таблица.ВысотаТаблицы(),1).ЦветТекста(255,0,0);
		Для Сч=1 По СписокСообщений.КоличествоСтрок() Цикл 
			СписокСообщений.ПолучитьСтрокуПоНомеру(Сч);
			ТипСообщения = СписокСообщений.ТипСообщения;  // тип сообщения - определяет его цвет 
			Значение1 = СписокСообщений.Форма;
			
			// выводим строку  сообщения
			Символ=?((ПустоеЗначение(Значение1)=0) И (ТипСообщения<>1), "V", "");
			ЧислоСтрокТекста=ВывестиТекстСообщенияВТаблицу(Символ, СписокСообщений.ТекстСообщения);
			
			ПоследняяСтрока=Таблица.ВысотаТаблицы();
			ПерваяСтрока=ПоследняяСтрока-ЧислоСтрокТекста+1;
			Область = Таблица.Область(ПерваяСтрока, 2, ПоследняяСтрока, 2);
			
			Если ПустоеЗначение(Значение1) = 0 тогда 
				// передали объект, который можно посмотреть - положим его в расшифровку
				Значение2 = СписокСообщений.Объект;
				Значение3 = СписокСообщений.Контрол;
				СписокРасшифровки = СоздатьОбъект("СписокЗначений");
				СписокРасшифровки.ДобавитьЗначение(?(ПустоеЗначение(Значение1) = 0,Значение1,""));
				СписокРасшифровки.ДобавитьЗначение(?(ПустоеЗначение(Значение2) = 0,Значение2,""));
				СписокРасшифровки.ДобавитьЗначение(?(ПустоеЗначение(Значение3) = 0,Значение3,""));
				Область.Расшифровка(СписокРасшифровки, 1);
			КонецЕсли;
			
			// раскрасим строку сообщения
			Если ТипСообщения = 1 Тогда // "красное" сообщение (фатальная ошибка)
				Область.ЦветТекста(255,0,0);
			ИначеЕсли ТипСообщения = -1 Тогда  // предупреждение
				Область.ЦветТекста(0,0,255);
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	Таблица.Опции(0,0,0,0,,"Трассировка");
	Таблица.Показать();
КонецПроцедуры	// ОтобразитьТаблицу

//******************************************************************************
//	Предопределенная процедура
//
Процедура ПриОткрытии()
	Попытка
		Форма.Заголовок("Комментарий выполняемых действий",0);
		Трассировка = Форма.Параметр;
		Если Трассировка.ПолучитьЗначение(2).КоличествоСтрок() > 0 Тогда
			Если Форма.МодальныйРежим() = 1 Тогда
			    ВывестиВОкноСообщений();
				СтатусВозврата(0); // не открываем обработку
			Иначе
				ОтобразитьТаблицу(); 
			КонецЕсли;
		Иначе
			СтатусВозврата(0); // не открываем обработку
		КонецЕсли;
	Исключение
		СтатусВозврата(0); // не открываем обработку
	КонецПопытки
КонецПроцедуры	// ПриОткрытии

//******************************************************************************
//	Предопределенная процедура
//
Процедура ПриПовторномОткрытии()
	Попытка
		Трассировка = Форма.Параметр;
		Если Трассировка.ПолучитьЗначение(2).КоличествоСтрок() > 0 Тогда
			Если Форма.МодальныйРежим() = 1 Тогда
			    ВывестиВОкноСообщений();
				СтатусВозврата(0); // не открываем обработку
			Иначе
				ОтобразитьТаблицу(); 
			КонецЕсли;
		Иначе
			СтатусВозврата(0); // не открываем обработку
		КонецЕсли;
	Исключение
		СтатусВозврата(0); // не открываем обработку
	КонецПопытки
КонецПроцедуры	// ПриПовторномОткрытии 

//******************************************************************************
//	Предопределенная процедура
//

Процедура ОбработкаЯчейкиТаблицы(Значение,Флаг)
	ТипОбъекта = ТипЗначения(Значение);
	Флаг = 0;   
	Если (ТипОбъекта = 100) Тогда
		ПереданнаяФорма = Значение.ПолучитьЗначение(1);
		ПереданныйОбъект = Значение.ПолучитьЗначение(2);
		ПереданныйКонтрол = СокрЛП(Значение.ПолучитьЗначение(3));
		Конт = "";
		ОткрытьФорму(ПереданнаяФорма,Конт);
		Если ТипЗначения(Конт) = 100 Тогда
			Если (ТипЗначения(ПереданнаяФорма) = 1) Тогда
				Если (ПустоеЗначение(ПереданныйОбъект) = 0) Тогда
					Конт.АктивизироватьОбъект(ПереданныйОбъект);
					Конт.Форма.Обновить(0);
				КонецЕсли;
			ИначеЕсли ПустоеЗначение(ПереданныйКонтрол) = 0 Тогда
				Конт.Активизировать(ПереданныйКонтрол);
				Конт.Форма.Обновить(0);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры  // ОбработкаЯчейкиТаблицы

