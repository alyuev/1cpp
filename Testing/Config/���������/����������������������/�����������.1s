Перем
		гТабМетоды,
		гТабСвойства
		;
	
Функция ВМ()
	Возврат СоздатьОбъект("ВыполняемыйМодуль");
КонецФункции

//*************************************************************************
Процедура ПолучитьДанныеОТипе(ТипОбъекта)

	Модуль = ВМ();

	гТабМетоды = СоздатьОбъект("ТаблицаЗначений");
	гТабСвойства = СоздатьОбъект("ТаблицаЗначений");
	
	Модуль.GetMethOfContext(СоздатьОбъект(ТипОбъекта), гТабМетоды, гТабСвойства);
	
КонецПроцедуры //ПолучитьДанныеОТипе

//*******************************************
Процедура Сформировать()
                  
	ПолучитьДанныеОТипе(ТипОбъекта);
	
гТабМетоды.ВыбратьСтроку("");	
гТабСвойства.ВыбратьСтроку("");	

КонецПроцедуры

//======================================================================
Процедура _ЗаписатьОбразОбъекта(ИмяКласса)
	
	ОБ = СоздатьОбъект("ВыполняемыйМодуль_ОбразыКлассов");
	Если ИмяКласса = "РасширениеФормы" Тогда // иначе без привязки к форме объект не удастся создать 
		ОБ.ЗаписатьОбразОбъекта(СоздатьОбъект(ИмяКласса));
	Иначе
		ОБ.ЗаписатьОбразОбъекта(ИмяКласса);
	КонецЕсли;
КонецПроцедуры // ЗаписатьОбразОбъекта()

//======================================================================
Процедура ЗаписатьОбразОбъекта()
	
	_ЗаписатьОбразОбъекта(ТипОбъекта);
КонецПроцедуры // ЗаписатьОбразОбъекта()

//======================================================================
Процедура ПриСменеВСпискеКлассов()
	ТипОбъекта = СписокКлассов.ПолучитьЗначение(СписокКлассов.ТекущаяСтрока());

КонецПроцедуры

//======================================================================
Процедура ПриСменеФлагаПроизвольныйКласс()
	Форма.ТипОбъекта.Доступность(ФлагПроизвольныйКласс);
КонецПроцедуры // ПриСменеФлагаПроизвольныйКласс()

Процедура ПолучитьКлассы1СПП(СписокКлассов)
        
	СпрКлассы = СоздатьОбъект("Справочник.Классы1СПП");
	СпрКлассы.ВыбратьЭлементы();
	Пока СпрКлассы.ПолучитьЭлемент() = 1 Цикл
		Если СпрКлассы.ФлагНепосредственногоСоздания = 1 Тогда
			СписокКлассов.ДобавитьЗначение(СокрЛП(СпрКлассы.Наименование));
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры	// ПолучитьКлассы1СПП

//============================================================
Процедура ПриОткрытии()
	
	MetaInfoClasses = СоздатьОбъект("MetaInfoClasses");
	СписокВсехКлассов1С = MetaInfoClasses.ПолучитьВсеИменаКлассов();
	СписокВсехКлассов1С.Выгрузить(СписокКлассов);
    
	ПолучитьКлассы1СПП(СписокКлассов);
	
	Для к=1 По СписокКлассов.РазмерСписка() Цикл
		Значение = СписокКлассов.ПолучитьЗначение(к);
		СписокКлассов.УстановитьЗначение(к, Значение);
	КонецЦикла;
	
	СписокКлассов.Сортировать();
                                                
	СписокКлассов.ТекущаяСтрока(1);
	ПриСменеВСпискеКлассов();
	
	ПриСменеФлагаПроизвольныйКласс();
КонецПроцедуры

//======================================================================
Процедура ЗаписатьОбразыВсехОбъектов()
	Перем ТипОбъекта;
	
	Для к=1 По СписокКлассов.РазмерСписка() Цикл
		ТипОбъекта = СписокКлассов.ПолучитьЗначение(к);
        
		Попытка
			_ЗаписатьОбразОбъекта(ТипОбъекта);
		Исключение
			Сообщить(ОписаниеОшибки(),"!!!");
		КонецПопытки;


	КонецЦикла;	
КонецПроцедуры // ЗаписатьОбразыВсехОбъектов()
