Функция Создать_Документ_Новый2(ПараметрСписок)
	_Сам2 = СоздатьОбъект("Документ_Новый2");
	
	фЗаменитьБазовыйОбъект = _Сам2.ЗаменитьБазовыйОбъект("Документ.Новый2", Контекст);
	
	ПараметрСписок.Установить("фЗаменитьБазовыйОбъект", фЗаменитьБазовыйОбъект);
	ПараметрСписок.Установить("Объект", _Сам2 );
	
	Возврат _Сам2;
КонецФункции    

Функция Сам_Выбран(ПараметрСписок)
	Перем _Сам2;
	
	_Сам2 = Создать_Документ_Новый2(ПараметрСписок);
	
	Возврат _Сам2.Выбран();
КонецФункции

Функция Сам_ДатаДок(ПараметрСписок)
	Перем _Сам2;
	
	_Сам2 = Создать_Документ_Новый2(ПараметрСписок);

	Возврат _Сам2.ДатаДок;
КонецФункции

