//------------------------------------ ------------------------------------ 
Функция ПолучитьВсеКакСтроку() Экспорт
//#if _LOAD_TIMER
  Перем Стр; Стр="";        
  Таб = Этот(Контекст).ПолучитьВсеКакТаблицу();
  Таб.Сортировать("-Время");
  //_Базовый.СортироватьПоВремени(1);
  //Для Ном=1 По _СписокОбщегоКоличества.РазмерСписка() Цикл          
  //  Режим=""; 
	//Количество = _СписокОбщегоКоличества.ПолучитьЗначение(Ном,Режим);
	//Время = _Базовый.Получить(Режим);
  //  Стр=?(ПустаяСтрока(Стр)=1,
  //    СокрЛП(Режим)+" - "+Время+" ("+Количество+")",
  //      Стр+РазделительСтрок+СокрЛП(Режим)+" - "+Время+" ("+Количество+")");
  //КонецЦикла; 
  Для Ном=1 По Таб.КоличествоСтрок() Цикл          
	Режим = Таб.ПолучитьЗначение(Ном,"Режим");
	Количество = Таб.ПолучитьЗначение(Ном,"Количество");
	Время = Таб.ПолучитьЗначение(Ном,"Время");
    Стр=?(ПустаяСтрока(Стр)=1,
      СокрЛП(Режим)+" - "+Время+" ("+Количество+")",
        Стр+РазделительСтрок+СокрЛП(Режим)+" - "+Время+" ("+Количество+")");
  КонецЦикла; 
  
  Возврат Стр;
//#else	
  Возврат "";
//#endif
КонецФункции //ПолучитьВсеКакСтроку
//------------------------------

//------------------------------------ ------------------------------------ 
Процедура СортироватьПоКоличеству(Направление) Экспорт
//#if _LOAD_TIMER
	_СписокОбщегоКоличества.Сортировать(Направление);
//#else	
//#endif
КонецПроцедуры // СортироватьПоКоличеству

//------------------------------------ ----------------------------------------------           
// получить результаты как таблицу значений с колонками "Режим","Время","Количество"  
//
// ТаблицаЗначений ПолучитьВсеКакТаблицу();
Функция ПолучитьВсеКакТаблицу() Экспорт
//#if _LOAD_TIMER
  Таб = СоздатьОбъект("ТаблицаЗначений");
  Таб.НоваяКолонка("Режим","Строка");
  Таб.НоваяКолонка("Время","Число");
  Таб.НоваяКолонка("Количество","Число");
  Для Ном=1 По _СписокОбщегоКоличества.РазмерСписка() Цикл          
    Режим=""; 
	Количество = _СписокОбщегоКоличества.ПолучитьЗначение(Ном,Режим);
	Время = _Базовый.Получить(Режим);
	Таб.НоваяСтрока();
	Таб.Режим = Режим; Таб.Время = Время; Таб.Количество = Количество;
  КонецЦикла; 
  
  Возврат Таб;
//#else	
  Возврат ПолучитьПустоеЗначение("ТаблицаЗначений");
//#endif
КонецФункции //ПолучитьВсеКакТаблицу
