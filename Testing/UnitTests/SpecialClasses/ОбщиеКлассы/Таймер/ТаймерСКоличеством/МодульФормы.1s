//---------------------------------
//Перем _СписокКоличества; // список на один цикл запуск-остановка таймера
Перем  _СписокОбщегоКоличества; // список на все Количество выполнения процесса
//---------------------------------
Перем _Базовый;

Функция Этот(Конт) Возврат Конт; КонецФункции 
//---------------------------------
//
Процедура Конструктор()    
////#if _LOAD_TIMER
  //_СписокКоличества=СоздатьОбъект("СписокЗначений");
  _СписокОбщегоКоличества=СоздатьОбъект("СписокЗначений");
  _Базовый = Этот(Контекст).ПолучитьБазовыйКласс();
////#endif	
КонецПроцедуры //Конструктор
//---------------------------------
 
Процедура Запуск(Режим="0") Экспорт
//#if _LOAD_TIMER 
//Сообщить("Таймер.Запуск() = "+Режим);
//  _СписокКоличества.Установить(Режим,0);
  _Базовый.Запуск(Режим);
//#endif	
КонецПроцедуры
//---------------------------------
 
Процедура Стоп(Режим="0") Экспорт
//#if _LOAD_TIMER
  _Базовый.Стоп(Режим);
  Количество = _СписокОбщегоКоличества.Получить(Режим);
  Количество = ?(ПустоеЗначение(Количество)=1,0,Количество);
  _СписокОбщегоКоличества.Установить(Режим, Количество + 1);
//#endif
КонецПроцедуры
//---------------------------------

//------------------------------------ ------------------------------------ 
// если ничего не передать, очищает все записи таймера
// иначе только для конкретного режима
Процедура Очистить(Режим="") Экспорт
//#if _LOAD_TIMER
	Если Режим="" Тогда
		//_СписокКоличества.УдалитьВсе();
		_СписокОбщегоКоличества.УдалитьВсе();
	Иначе
		//_СписокКоличества.Установить(Режим,0);
		_СписокОбщегоКоличества.Установить(Режим,0);
	КонецЕсли;    
	_Базовый.Очистить();
//#endif
КонецПроцедуры //Очистить
          
Функция ПолучитьКоличество(Режим="0") Экспорт
//#if _LOAD_TIMER
  Возврат _СписокОбщегоКоличества.Получить(Режим);
//#else	
  Возврат 0;
//#endif
КонецФункции //ПолучитьКоличество
//------------------------------
          
Функция ПолучитьКоличествоКакСтроку(Режим="0") Экспорт
//#if _LOAD_TIMER
  Стр = СокрЛП(Режим)+" - "+ _СписокОбщегоКоличества.Получить(Режим);
  Возврат Стр;
//#else	
  Возврат "";
//#endif
КонецФункции //ПолучитьКоличествоКакСтроку
//------------------------------

//------------------------------------ ------------------------------------ 
Функция ПолучитьВсеКоличествоКакСтроку() Экспорт
//#if _LOAD_TIMER
  Перем Стр; Стр="";
  Этот(Контекст).СортироватьПоКоличеству(1);

  Для Ном=1 По _СписокОбщегоКоличества.РазмерСписка() Цикл          
    Режим=""; 
	Количество = _СписокОбщегоКоличества.ПолучитьЗначение(Ном,Режим);
    Стр=?(ПустаяСтрока(Стр)=1,
      СокрЛП(Режим)+" - "+Количество,
        Стр+РазделительСтрок+СокрЛП(Режим)+" - "+Количество);
  КонецЦикла; 
  
  Возврат Стр;
//#else	
  Возврат "";
//#endif
КонецФункции //ПолучитьВсеКоличествоКакСтроку
//------------------------------

//------------------------------------ ------------------------------------ 
Функция ПолучитьВсеВремяКакСтроку() Экспорт
//#if _LOAD_TIMER
  Возврат _Базовый.ПолучитьВсеКакСтроку();
//#else	
  Возврат "";
//#endif
КонецФункции //ПолучитьВсеВремяКакСтроку
