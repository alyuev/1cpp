////#define _DEBUG
//#define _LOAD_TIMER

//Подсчет общего времени выполнения.
//Особенно удобен для вычисления времени выполнения функций, чей код выполняется не один раз.
//Может использоваться для замера производительности классов 1С++.
//Нужно просто поместить в начало функции Таймер.Запуск(), в окончание Таймер.Стоп()
//затем после окончания всего процесса выполнить соответствующий метод Получить,ПолучитьВВидеСтроки,ПолучитьВсе
//если задана директива _DEBUG, методы ничего не делают - просто пустышка
//
//На создание такой реализации класса натолкнул класс TIMEModul от Winter-а.

class Общие.Таймер = Таймер.ert
{
// запустить в очередной раз подсчет для метода Режим
  void    Запуск(Строка Режим="0");
// остановить подсчет для метода Режим
  void    Стоп(Строка Режим="0");
  
// обнулить время выполнения для метода Режим, если указан
// если Режим="", обнуляет все  
  void    Очистить(Строка Режим="");
  
// время выполнения метода Режим в виде числа  
  Число   Получить(Строка Режим="0"); 
// время выполнения метода Режим в виде строки
  Строка  ПолучитьКакСтроку(Строка Режим="0");
  
// время выполнения всех методов
  Строка  ПолучитьВсеКакСтроку(); 
  
  void СортироватьПоВремени(Число Направление);
}


class Общие.ТаймерСКоличеством = ТаймерСКоличеством.ert : Общие.Таймер
{
// запустить в очередной раз подсчет для метода Режим
  void    Запуск(Строка Режим="0");
// остановить подсчет для метода Режим
  void    Стоп(Строка Режим="0");
  
// обнулить время выполнения для метода Режим, если указан
// если Режим="", обнуляет все  
  void    Очистить(Строка Режим="");
  
// количество запусков действия Режим в виде числа
  Число   ПолучитьКоличество(Строка Режим="0"); 
// количество запусков выполнения метода Режим в виде строки
  Строка  ПолучитьКоличествоКакСтроку(Строка Режим="0");
  
// количество запусков всех методов
  Строка  ПолучитьВсеКоличествоКакСтроку();    
                                          
// получить результаты как таблицу значений с колонками "Режим","Время","Количество"
  ТаблицаЗначений ПолучитьВсеКакТаблицу();
  
// время + количество выполнения всех методов
  Строка  ПолучитьВсеКакСтроку(); 
  
  void СортироватьПоКоличеству(Число Направление);
  
}
