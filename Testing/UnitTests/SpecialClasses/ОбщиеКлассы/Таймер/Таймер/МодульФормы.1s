// E-mail: artbear@bashnet.ru
                      
////#ifdef _DEBUG
////		#define _LOAD_TIMER
////#endif

//---------------------------------
Перем _СписокВремён; // список на один цикл запуск-остановка таймера
Перем  _СписокОбщихВремён; // список на все время выполнения процесса
//---------------------------------
 
Функция Этот(Конт) Возврат Конт; КонецФункции 
//---------------------------------
//
Процедура Конструктор()    
////#if _LOAD_TIMER
  _СписокВремён=СоздатьОбъект("СписокЗначений");
  _СписокОбщихВремён=СоздатьОбъект("СписокЗначений");
//Сообщить("Таймер.Конструктор = ");  
////#endif	
КонецПроцедуры //Конструктор
//---------------------------------
 
Процедура Запуск(Режим="0") Экспорт
//#if _LOAD_TIMER 
//Сообщить("Таймер.Запуск() = "+Режим);
	//лТаймер = СоздатьОбъект("Общие.Таймер");
	//лТаймер.Стоп(Режим);
  _СписокВремён.Установить(Режим,Число(_GetPerformanceCounter()));
//#endif	
КонецПроцедуры
//---------------------------------
 
Процедура Стоп(Режим="0") Экспорт
//#if _LOAD_TIMER
  КонецИнтервала = Число(_GetPerformanceCounter());
  НачалоИнтервала = Число(_СписокВремён.Получить(Режим));
  ПредВремя = Число(_СписокОбщихВремён.Получить(Режим));
  _СписокОбщихВремён.Установить(Режим,ПредВремя+КонецИнтервала - НачалоИнтервала);
//Сообщить("Таймер.Стоп() = "+Режим);
//#endif
КонецПроцедуры
//---------------------------------

//------------------------------------ ------------------------------------ 
// если ничего не передать, очищает все записи таймера
// иначе только для конкретного режима
Процедура Очистить(Режим="") Экспорт
//#if _LOAD_TIMER
	Если Режим="" Тогда
		_СписокВремён.УдалитьВсе();
		_СписокОбщихВремён.УдалитьВсе();
	Иначе
		_СписокВремён.Установить(Режим,0);
		_СписокОбщихВремён.Установить(Режим,0);
	КонецЕсли;
//#endif
КонецПроцедуры //Очистить
          
Функция Получить(Режим="0") Экспорт
//#if _LOAD_TIMER
  Возврат _СписокОбщихВремён.Получить(Режим);
//#else	
  Возврат 0;
//#endif
КонецФункции
//------------------------------
          
Функция ПолучитьКакСтроку(Режим="0") Экспорт
//#if _LOAD_TIMER
  Стр = СокрЛП(Режим)+" - "+ _СписокОбщихВремён.Получить(Режим);
  Возврат Стр;
//#else	
  Возврат "";
//#endif
КонецФункции
//------------------------------

//------------------------------------ ------------------------------------ 
Функция ПолучитьВсеКакСтроку() Экспорт
//#if _LOAD_TIMER
  Перем Стр; Стр="";
  //Этот(Контекст).СортироватьПоВремени(1);
  Для Ном=1 По _СписокОбщихВремён.РазмерСписка() Цикл          
    Режим=""; 
	Время = _СписокОбщихВремён.ПолучитьЗначение(Ном,Режим);
    Стр=?(ПустаяСтрока(Стр)=1,
      СокрЛП(Режим)+" - "+Время,
        Стр+РазделительСтрок+СокрЛП(Режим)+" - "+Время);
  КонецЦикла; 
  
  Возврат Стр;
//#else	
  Возврат "";
//#endif
КонецФункции
//------------------------------     

//------------------------------------ ------------------------------------ 
Процедура СортироватьПоВремени(Направление) Экспорт
//#if _LOAD_TIMER
	_СписокОбщихВремён.Сортировать(Направление);
//#else	
//#endif
КонецПроцедуры // СортироватьПоВремени 

