class Общие.АнализКоманднойСтроки1С = Общие.АнализКоманднойСтроки1С.txt
{
// в конструкторе по умолчанию разбирается командная строка запуска 1С, 
// т.е. в вызове метода "РазобратьКоманднуюСтроку" в принципе нет необходимости
  Число РазобратьКоманднуюСтроку(Строка РазбираемаяСтрока);
  
  Число ПолучитьКоличествоПараметров();
// с учетом нулевого параметра,
// т.е. ПолучитьПараметрПоНомеру(0) получить имя исполняемого файла 1С
  Строка ПолучитьПараметрПоНомеру(Число Индекс);                             
                             
// пример вызова: ПолучитьПараметрПоНаименованию("/D")
// 1) для параметра /D выдается /D
// 2) для параметра /DC:\Base выдается C:\Base
// 3) для параметра /D"C:\Base" выдается C:\Base
// 4) для параметра /D"C:\Base\" (внимание на последний слеш перед кавычкой) все равно выдается C:\Base\
// 5) возможен также вариант /D:"C:\Base\" (внимание на двоеточие после /D) поведение аналогично п.2-4
  Неопределенный ПолучитьПараметрПоНаименованию(Строка Параметр);

// если Параметр это число, возвращается параметр по номеру
// если Параметр это строка, возвращается параметр по наименованию
  Неопределенный ПолучитьПараметр(Неопределенный Параметр);

}

class Общие.Автозагрузка = Общие.Автозагрузка.txt
{                
// для переопределения в подчиненных классах
  Число ВыполнитьАнализ();                             

 // выполнить обработку, название которой передано в параметрах 
  void ВыполнитьОбработку(Строка ИмяОбработки, Строка Команда);
  
 // выполнить метод класса, название которого передано в параметрах 
 // если метод не задан, просто создаем класс (считаю, что основное действие в конструкторе)
 // перед этим проверяю наличие такого класса и такого метода      
 // в случае наличия наименования класса, но отсутствия подобного метода никаких действий не выполняется
  void ВыполнитьМетодКласса(Строка ИмяКласса, Строка МетодКласса="");
}

class Артур.Общие = Артур_Общие.txt : ОбщиеМетоды  // +als
{ 

  void _ОткрытьФорму(Знач Строка НазваниеФайла, Неопределенный Параметры="", Знач Число Модально = 0, Знач Число ВнешнийОтчет = 1);

  void РедакторТЗ(Знач ТаблицаЗначений ТЗ, Строка Заголовок="", Число Модально=0, Число ВнешнийОтчет=0);
                  
// -- ADirks -- 
	Строка НайтиФайлВнешнегоОтчета(Строка ИмяОтчета, Знач Неопределенный сзПути);
	Число ОткрытьОбработку(Знач Строка ИмяОбработки, Неопределенный Параметры, Число Модально, Знач Неопределенный Внешняя, Число QuietMode = 0);
	void РедакторТЗ(Знач Неопределенный ТЗ, Строка Заголовок = "", Число Модально = 0, Знач Число ВнешнийОтчет = 0, Число АвтоШирина = 0, Число ТолькоПросмотр = 0);
// -- завершение

// возвращает значение в виде "Справочник.Сотрудники","Элемент.Сотрудники","Документ.АвансовыйОтчет"
// "ВнешнийОтчет.Пример.ert", "ЖурналРасчетов","ЖурналДокументов","Отчет".
// ??? для 3 последних видов и обработок не нашел способа определить вид ???
  Строка ПолучитьВидОбъекта(ГрупповойКонтекст Конт);
  
  void ПроверкаФормы(ГрупповойКонтекст Конт) Экспорт
  
//ВызовДругойФормы() - вызов дополнительной формы, возможно внешней, вместо переданной
// в случае успеха возвращает 1, иначе 0
  Число ВызовДругойФормы(ГрупповойКонтекст Конт);                   
  
// найти форму в каталогах внешних форм из глСписокПутейВнешнихФорм;
// в случае успеха возвращает полный путь к форме иначе ""
  Строка НайтиВнешнююФорму(Строка НазваниеФормы);
  
// добавить к кнопке на форме формулу и поменять ее название, если нужно
// в случае успех возвращает 1, иначе 0
// СтароеНазваниеКнопки, Неопределенный НовоеНазваниеКнопки - либо строка либо СписокЗначений, из которого ищутся подходящие
// если из списка ничего не найдено, используется последнее значение. 
// Если передана строка или список с одним элементом, то они используются в любом случае
  //Число УстановитьКнопкуНаФорме(ГрупповойКонтекст Конт, Строка Формула, Строка СтароеНазваниеКнопки, Строка НовоеНазваниеКнопки = "");
  Число УстановитьКнопкуНаФорме(ГрупповойКонтекст Конт, Строка Формула, Неопределенный СтароеНазваниеКнопки, Неопределенный НовоеНазваниеКнопки = "");
  
//// заменить название кнопки на форме и ее формулу
//// в случае успех возвращает 1, иначе 0
//// СтароеНазваниеКнопки, Неопределенный НовоеНазваниеКнопки - либо строка либо СписокЗначений, из которого ищутся подходящие
//// если из списка ничего не найдено, используется последнее значение. 
//// Если передана строка или список с одним элементом, то они используются в любом случае
//  //Число ЗаменитьКнопкуНаФорме(ГрупповойКонтекст Конт, Строка Формула, Строка СтароеНазваниеКнопки, Строка НовоеНазваниеКнопки = "");
//  Число ЗаменитьКнопкуНаФорме(ГрупповойКонтекст Конт, Строка Формула, Неопределенный СтароеНазваниеКнопки, Неопределенный НовоеНазваниеКнопки = "");
  

//------------------------------------ ------------------------------------ 
//СуществуетКнопкаНаФорме(Конт,Название1, фПоИдентификатору=0)
// Название - либо строка либо СписокЗначений, из которого ищутся подходящие
// если из списка ничего не найдено, используется последнее значение. 
// Если передана строка или список с одним элементом, то они используются в любом случае
// фПоИдентификатору = 1, ищем по идентификатору, 0 - по названию
// возвращает: 1 - кнопка существует, 0 - нет
  Число СуществуетКнопкаНаФорме(ГрупповойКонтекст Конт,Неопределенный Название, Число фПоИдентификатору=0);

// глМаксимизироватьОкно - делает сабж для любого окна
// выполняю через вызов меню программы
// вызывать в конце процедуры "ПриОткрытии" из модуля формы
  void глМаксимизироватьОкно();

//ЗакрытьОкноСообщений - закрывает окно сообщений
  void ЗакрытьОкноСообщений();

//УстановитьМасштаб() - установить масштаб печатной формы.
// выполняю через вызов меню программы
// Параметры: Масштаб - 50,75.100.125.150.200 %%
  void УстановитьМасштаб(Число Масштаб);
                                     
// Обновление внешнего отчета с автоматическим его закрытием и открытием в новом окне
// Пример вызова из внешнего отчета:
// об = СоздатьОбъект("Артур.Общие"); об.ПерезагрузитьОтчет(Контекст); об = "";
  void ПерезагрузитьОтчет(ГрупповойКонтекст Конт);
  
// Данная функция получает некую строку-условие вида "Количество<>0" и 
// ссылку на документ/справочник (контекст) или переменная-значение.
// Если указанное условие выполняется функция возвращает число 1, иначе число 0.

// В переменную Конт может передаваться не только контекст, но и собственно проверяемое 
// значение (переменная), например, глПроверкаУсловия(ЗначВвода,"ЗначВвода>2")

// Типы возможный условий:
// Равно  "="   Например "Курс=1"
// Меньше "<"   Например "Курс<1"
// Больше ">"   Например "Курс>1"
// БольшеИлиРавно ">="    Например "Курс>=1"
// МеньшеИлиРавно "<="    Например "Курс<=1"
// Не равно "<>"  Например "Курс<>1"
// Не пусто "#"   Например "Курс#"
// Пусто  "!#"  Например "Курс!#"
// Прим.: следует учитывать передачу синонимов, например: "Курс|Курс валюты>1"
  Число ПроверкаУсловия(Неопределенный Конт, Строка Условие);  
  
// Перекинуть таблицу отчета в Excel и открыть его там
  void ТаблицуОтчетаВExcel(Таблица Таб, Строка ИмяФайла="", Строка ИмяКаталога="");
         
// Приостановить выполнение программы на нужное время
  void ПриостановитьВыполнение(СекЖдать=0,МожноПрервать=0,Сообщение="Ждите ...");
         
//  Помечает, снимает или инвертирует установленные пометки в списке на форме
//
//	Параметры:
//		РежимПометки - режим установки пометок ("Все", "Сброс", "Инверсия")
//
  void ВклОбъекты(Строка РежимПометки, СписокЗначений СписокНаФорме);
  
// является ли переданный экземпляр переданным типом или производным от него
	Число ЯвляетсяТипом(Неопределенный ЭкземплярКласса, Строка ИмяКласса);
                   
// получить модуль числа
	Число ABS(Число Параметр);                                  
	
// вывести в окне сообщений данные о переменной
// типа: гПодразделение = "ЖЭУ-02"
// ВНИМАНИЕ: имя переменной обязательно должно быть в кавычках
	void СообщитьОтладка(Строка ИмяПеременной);
                
//------------------------------------ ------------------------------------ 
// выполнить произвольную процедуру или функцию с параметрами
// А при работе через "ВыполняемыйМодуль" почти все прекрасно,
// кроме того, что при вызове процедуры в окне сообщений появляется ошибка компиляции, вызванная преднамеренно
//
	Неопределенный ВыполнитьВКонтексте(Неопределенный Конт, Строка ИмяПроцедурыФункции, Строка СтрПараметрыПроцедурыФункции = "");
	
// выполнить произвольную процедуру с параметрами
	void ВыполнитьПроцедуруВКонтексте(Неопределенный Конт, Строка ИмяПроцедуры, Строка СтрПараметрыПроцедуры = "");
   
// выбросить исключение с показом ошибки
	void ВыброситьИсключение(Строка ТекстИсключения);
	
//    раскладывает один большой период на периоды по месяцам
//    формирует таблицу дат начала и окончания в порядке возрастания,
//    например, период 12.02.2002-19.05.2002 будет преобразован в таблицу:
//      12.02.2002  28.02.2002
//    01.03.2002  31.03.2002
//    01.04.2002  30.04.2002
//    01.05.2002  19.05.2002
	ТаблицаЗначений РазложитьПериодПоМесячнымИнтервалам(Дата ДатаНачала, Дата ДатаОкончания);
                                  
// проверить ИНН сотрудника	
	Число ПроверкаИННФизЛица(INN);

// http://www.sinor.ru/~my1c/knowhow/uni_conv.html
	Строка Из_10_В_Любую(Число Знач Значение=0, Число Нотация=36);
	Число Из_Любой_В_10(Строка Знач Значение="0", Число Нотация=36);

}

class ПомощникСозданияКласса = ПомощникСозданияКласса.txt
{}